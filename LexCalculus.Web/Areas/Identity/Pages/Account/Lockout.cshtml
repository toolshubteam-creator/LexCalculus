@page
@model LockoutModel
@{
    ViewData["Title"] = "Hesap Kilitli";
}

<div class="form-section form-section--narrow">
    <h1 class="form-section__title">Hesap Geçici Olarak Kilitli</h1>

    <div class="form-section__message form-section__message--error" role="alert">
        <p>
            Çok fazla başarısız giriş denemesi yapıldı. Hesabınız <strong>15 dakika</strong>
            süreyle kilitlendi.
        </p>
        <p>
            Lütfen daha sonra tekrar deneyin. Şifrenizi unuttuysanız aşağıdaki bağlantıyı
            kullanabilirsiniz.
        </p>
    </div>

    <div class="form-section__cta">
        <a asp-page="./ForgotPassword">Şifremi unuttum</a>
    </div>
</div>
