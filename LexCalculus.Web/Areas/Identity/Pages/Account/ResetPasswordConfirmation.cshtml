@page
@model ResetPasswordConfirmation
@{
    ViewData["Title"] = "Şifre Sıfırlandı";
}

<section class="hero">
    <div class="hero__eyebrow">— Tamamlandı —</div>
    <h1 class="hero__title">Şifren <em>sıfırlandı</em></h1>
    <p class="hero__lead">Yeni şifrenle giriş yapabilirsin.</p>
</section>

<div style="text-align: center; margin-top: var(--sp-12);">
    <a class="btn btn--primary" asp-area="Identity" asp-page="/Account/Login">Giriş sayfasına git</a>
</div>
