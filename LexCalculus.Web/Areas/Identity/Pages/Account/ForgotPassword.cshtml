@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<section class="hero">
    <div class="hero__eyebrow">— Şifre kurtarma —</div>
    <h1 class="hero__title">Şifreni mi <em>unuttun?</em></h1>
    <p class="hero__lead">E-posta adresini gir, sıfırlama bağlantısını sana göndereceğiz.</p>
</section>

<div style="max-width: 480px; margin: 0 auto;">
    <form method="post" class="form-section">
        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field">
            <label asp-for="Input.Email" class="field__label field__label--required">
                E-posta <span class="required">*</span>
            </label>
            <input asp-for="Input.Email" class="field__input" autocomplete="email" placeholder="ornek@eposta.com" />
            <span asp-validation-for="Input.Email" class="field-hint"></span>
        </div>

        <button type="submit" class="btn btn--primary btn--block">Sıfırlama Bağlantısını Gönder</button>
    </form>

    <div class="info-box" style="margin-top: var(--sp-6);">
        <strong>Not:</strong> E-posta gönderim altyapısı henüz kurulmamıştır (Faz 5'te etkinleşecek). Şimdilik bu formu submit ettiğinizde sayfa "ForgotPasswordConfirmation" sayfasına yönlenir, ancak gerçek e-posta gönderilmez.
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
