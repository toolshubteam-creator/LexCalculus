@page
@model RegisterModel
@{
    ViewData["Title"] = "Kayıt Ol";
}

<section class="hero">
    <div class="hero__eyebrow">Anno MMXXVI</div>
    <h1 class="hero__title">Yeni <em>hesap</em> oluştur</h1>
    <p class="hero__lead">Lex Calculus topluluğuna katıl. Hesaplama araçları, mesleki bağlantılar ve mevzuat takibi seni bekliyor.</p>
</section>

<form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-section form-section--narrow">
    <h2 class="form-section__title">Hesap Bilgileri</h2>

    <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

    <div class="field">
        <label asp-for="Input.Email" class="field__label field__label--required">
            E-posta <span class="required">*</span>
        </label>
        <input asp-for="Input.Email" class="field__input" autocomplete="username" aria-required="true" placeholder="ornek@eposta.com" />
        <span asp-validation-for="Input.Email" class="field-hint"></span>
    </div>

    <div class="field">
        <label asp-for="Input.FullName" class="field__label field__label--required">
            Ad-Soyad <span class="required">*</span>
        </label>
        <input asp-for="Input.FullName" class="field__input" autocomplete="name" aria-required="true" maxlength="100" />
        <span asp-validation-for="Input.FullName" class="field-hint"></span>
    </div>

    <div class="field">
        <label asp-for="Input.Password" class="field__label field__label--required">
            Şifre <span class="required">*</span>
        </label>
        <input asp-for="Input.Password" class="field__input" autocomplete="new-password" aria-required="true" type="password" />
        <span asp-validation-for="Input.Password" class="field-hint"></span>
    </div>

    <div class="field">
        <label asp-for="Input.ConfirmPassword" class="field__label field__label--required">
            Şifre Tekrar <span class="required">*</span>
        </label>
        <input asp-for="Input.ConfirmPassword" class="field__input" autocomplete="new-password" aria-required="true" type="password" />
        <span asp-validation-for="Input.ConfirmPassword" class="field-hint"></span>
    </div>

    <div class="field">
        <label asp-for="Input.MeslekTuru" class="field__label">Mesleğiniz</label>
        <select asp-for="Input.MeslekTuru" id="Input_MeslekTuru" class="field__input">
            <option value="">— Belirtmek istemiyorum —</option>
            <option value="1">Avukat</option>
            <option value="2">Hâkim</option>
            <option value="3">Savcı</option>
            <option value="4">Bilirkişi</option>
            <option value="5">Mali Müşavir</option>
            <option value="99">Diğer</option>
        </select>
        <span asp-validation-for="Input.MeslekTuru" class="field-hint"></span>
    </div>

    <div class="field is-hidden" data-meslek-diger-wrapper>
        <label asp-for="Input.MeslekTuruDiger" class="field__label">Mesleğinizi yazınız</label>
        <input asp-for="Input.MeslekTuruDiger" class="field__input" maxlength="50" />
        <span asp-validation-for="Input.MeslekTuruDiger" class="field-hint"></span>
    </div>

    <div class="field">
        <label asp-for="Input.BaroNo" class="field__label">Baro/Sicil Numarası</label>
        <input asp-for="Input.BaroNo" class="field__input" maxlength="50" />
        <span asp-validation-for="Input.BaroNo" class="field-hint"></span>
    </div>

    <button type="submit" class="btn btn--primary btn--block">Hesabı Oluştur</button>

    <div class="form-section__cta">
        Zaten hesabın var mı?
        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Giriş yap</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/register.js" asp-append-version="true"></script>
}
