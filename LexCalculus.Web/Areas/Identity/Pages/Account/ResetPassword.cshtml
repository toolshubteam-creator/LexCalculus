@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Şifre Sıfırla";
}

<section class="hero">
    <div class="hero__eyebrow">— Yeni şifre —</div>
    <h1 class="hero__title">Şifreni <em>sıfırla</em></h1>
    <p class="hero__lead">Yeni şifreni belirleyerek hesabına erişimini geri kazan.</p>
</section>

<div style="max-width: 480px; margin: 0 auto;">
    <form method="post" class="form-section">
        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <input asp-for="Input.Code" type="hidden" />

        <div class="field">
            <label asp-for="Input.Email" class="field__label field__label--required">E-posta <span class="required">*</span></label>
            <input asp-for="Input.Email" class="field__input" autocomplete="email" />
            <span asp-validation-for="Input.Email" class="field-hint"></span>
        </div>

        <div class="field">
            <label asp-for="Input.Password" class="field__label field__label--required">Yeni Şifre <span class="required">*</span></label>
            <input asp-for="Input.Password" class="field__input" type="password" autocomplete="new-password" />
            <span asp-validation-for="Input.Password" class="field-hint"></span>
        </div>

        <div class="field">
            <label asp-for="Input.ConfirmPassword" class="field__label field__label--required">Şifre Tekrar <span class="required">*</span></label>
            <input asp-for="Input.ConfirmPassword" class="field__input" type="password" autocomplete="new-password" />
            <span asp-validation-for="Input.ConfirmPassword" class="field-hint"></span>
        </div>

        <button type="submit" class="btn btn--primary btn--block">Şifreyi Sıfırla</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
