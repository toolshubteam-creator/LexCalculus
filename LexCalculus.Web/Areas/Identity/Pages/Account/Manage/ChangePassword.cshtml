@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Şifre Değiştir";
    ViewData["NoIndex"] = true;
}

<div class="form-section form-section--narrow">
    <h1 class="form-section__title">Şifre Değiştir</h1>

    @if (Model.StatusMessage != null)
    {
        <div class="form-section__message form-section__message--success" role="status">
            @Model.StatusMessage
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="form-section__message form-section__message--error"></div>

    <form method="post" id="change-password-form">
        <div class="field">
            <label asp-for="Input.OldPassword" class="field__label field__label--required">
                Mevcut Şifre <span class="required">*</span>
            </label>
            <input asp-for="Input.OldPassword" class="field__input" type="password" autocomplete="current-password" aria-required="true" />
            <span asp-validation-for="Input.OldPassword" class="field-hint"></span>
        </div>

        <div class="field">
            <label asp-for="Input.NewPassword" class="field__label field__label--required">
                Yeni Şifre <span class="required">*</span>
            </label>
            <input asp-for="Input.NewPassword" class="field__input" type="password" autocomplete="new-password" aria-required="true" />
            <span asp-validation-for="Input.NewPassword" class="field-hint">En az 8 karakter; büyük/küçük harf, rakam ve özel karakter içermeli.</span>
        </div>

        <div class="field">
            <label asp-for="Input.ConfirmPassword" class="field__label field__label--required">
                Yeni Şifre Tekrar <span class="required">*</span>
            </label>
            <input asp-for="Input.ConfirmPassword" class="field__input" type="password" autocomplete="new-password" aria-required="true" />
            <span asp-validation-for="Input.ConfirmPassword" class="field-hint"></span>
        </div>

        <div class="form-section__actions">
            <button type="submit" class="btn btn--primary">Şifreyi Güncelle</button>
            <a asp-page="./Index" class="form-section__cta-link-btn">Vazgeç</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
