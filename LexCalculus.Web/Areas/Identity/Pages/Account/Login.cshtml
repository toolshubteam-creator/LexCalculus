@page
@model LoginModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<section class="hero">
    <div class="hero__eyebrow">Anno MMXXVI</div>
    <h1 class="hero__title">Hesabına <em>giriş yap</em></h1>
    <p class="hero__lead">Hukuki hesaplama araçlarına ve mesleki ağa erişmek için hesabınla devam et.</p>
</section>

<div style="max-width: 480px; margin: 0 auto;">
    <form id="account" method="post" class="form-section">
        <h2 class="form-section__title">Giriş Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field">
            <label asp-for="Input.Email" class="field__label field__label--required">
                E-posta <span class="required">*</span>
            </label>
            <input asp-for="Input.Email" class="field__input" autocomplete="username" aria-required="true" placeholder="ornek@eposta.com" />
            <span asp-validation-for="Input.Email" class="field-hint"></span>
        </div>

        <div class="field">
            <label asp-for="Input.Password" class="field__label field__label--required">
                Şifre <span class="required">*</span>
            </label>
            <input asp-for="Input.Password" class="field__input" autocomplete="current-password" aria-required="true" type="password" />
            <span asp-validation-for="Input.Password" class="field-hint"></span>
        </div>

        <div class="field">
            <label class="field__label" style="display: flex; align-items: center; gap: var(--sp-2);">
                <input asp-for="Input.RememberMe" type="checkbox" />
                <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
            </label>
        </div>

        <button type="submit" class="btn btn--primary btn--block">Giriş Yap</button>

        <div style="margin-top: var(--sp-6); text-align: center; font-family: var(--font-mono); font-size: var(--fs-meta); letter-spacing: var(--tracking-wide); text-transform: uppercase;">
            <a asp-page="./ForgotPassword" style="color: var(--burgundy);">Şifremi unuttum</a>
            &nbsp;·&nbsp;
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" style="color: var(--burgundy);">Hesap oluştur</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
