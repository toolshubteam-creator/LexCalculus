@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<nav class="admin-sidebar__nav" aria-label="Yönetim navigasyonu">
    <a class="admin-nav-link @(currentController == "Home" ? "admin-nav-link--active" : "")"
       asp-area="Admin" asp-controller="Home" asp-action="Index">
        <span class="admin-nav-link__label">Dashboard</span>
    </a>
    <a class="admin-nav-link @(currentController == "Parameters" ? "admin-nav-link--active" : "")"
       asp-area="Admin" asp-controller="Parameters" asp-action="Index">
        <span class="admin-nav-link__label">Parametreler</span>
    </a>
    <a class="admin-nav-link @(currentController == "Email" ? "admin-nav-link--active" : "")"
       asp-area="Admin" asp-controller="Email" asp-action="Test">
        <span class="admin-nav-link__label">E-posta Testi</span>
    </a>
    <a class="admin-nav-link @(currentController == "Hesaplar" ? "admin-nav-link--active" : "")"
       asp-area="Admin" asp-controller="Hesaplar" asp-action="Index">
        <span class="admin-nav-link__label">Hesap Geçmişi</span>
    </a>
    <a class="admin-nav-link"
       href="/admin/hangfire"
       target="_blank"
       rel="noopener">
        <span class="admin-nav-link__label">Background Jobs</span>
        <span class="admin-nav-link__hint">↗</span>
    </a>
</nav>
