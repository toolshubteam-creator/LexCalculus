@using LexCalculus.Core.Entities.Moderation
@model LexCalculus.Web.Areas.Admin.Models.ContentReports.ContentReportListVm

<div class="admin-page">
    @if (TempData["AdminSuccess"] is string success)
    {
        <div class="admin-banner admin-banner--success" role="status">@success</div>
    }
    @if (TempData["AdminError"] is string error)
    {
        <div class="admin-banner admin-banner--error" role="alert">@error</div>
    }

    <header class="admin-page__header">
        <div>
            <h1 class="admin-page__title">Şikayetler</h1>
            <p class="admin-page__subtitle">
                @Model.TotalPending bekleyen şikayet
            </p>
        </div>
    </header>

    @if (Model.Items.Count == 0)
    {
        <div class="admin-card admin-card--empty">
            <p class="admin-card__body">Bekleyen şikayet bulunmuyor.</p>
        </div>
    }
    else
    {
        <div class="param-table-wrap">
            <table class="param-table">
                <thead>
                    <tr>
                        <th>Tip</th>
                        <th>İçerik</th>
                        <th>Yazar</th>
                        <th>Şikayet Sayısı</th>
                        <th>En Son</th>
                        <th class="param-table__actions">Eylem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr class="param-table__row">
                            <td>
                                @if (item.TargetType == ContentReportTargetType.Post)
                                {
                                    <span class="param-badge param-badge--post">Makale</span>
                                }
                                else
                                {
                                    <span class="param-badge param-badge--comment">Yorum</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.TargetUrl))
                                {
                                    <a href="@item.TargetUrl" target="_blank" rel="noopener">@item.TargetTitle</a>
                                }
                                else
                                {
                                    <span>@item.TargetTitle</span>
                                }
                            </td>
                            <td>@item.AuthorDisplayName</td>
                            <td><strong>@item.ReportCount</strong></td>
                            <td>@item.LatestReportAt.ToString("d MMMM yyyy HH:mm")</td>
                            <td class="param-table__actions">
                                <a class="admin-link"
                                   asp-action="Detail"
                                   asp-route-type="@((int)item.TargetType)"
                                   asp-route-id="@item.TargetId">İncele</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
