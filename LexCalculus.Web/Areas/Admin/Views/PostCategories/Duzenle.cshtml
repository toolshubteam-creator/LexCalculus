@model LexCalculus.Web.Areas.Admin.Models.PostCategories.PostCategoryFormVm

<div class="admin-page">
    <header class="admin-page__header">
        <h1 class="admin-page__title">Kategori Düzenle</h1>
        <p class="admin-page__subtitle">
            Adı değiştirirseniz slug yeniden üretilir. Slug çakışırsa hata döner.
        </p>
    </header>

    <div asp-validation-summary="ModelOnly" class="admin-banner admin-banner--error"></div>

    <div class="admin-form-layout">
        <form method="post" asp-action="Duzenle" asp-route-id="@Model.Id" class="admin-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="admin-form__field">
                <label class="admin-form__label" asp-for="Name">Kategori Adı</label>
                <input class="admin-form__input" asp-for="Name" maxlength="80" />
                <span asp-validation-for="Name" class="admin-form__error"></span>
            </div>

            <div class="admin-form__field">
                <label class="admin-form__label" asp-for="Description">Açıklama</label>
                <textarea class="admin-form__input" asp-for="Description" rows="3"
                          maxlength="500"></textarea>
                <span asp-validation-for="Description" class="admin-form__error"></span>
            </div>

            <div class="admin-form__field">
                <label class="admin-form__label" asp-for="DisplayOrder">Sıra</label>
                <input class="admin-form__input" asp-for="DisplayOrder" type="number" min="0" />
                <span asp-validation-for="DisplayOrder" class="admin-form__error"></span>
            </div>

            <div class="admin-form__field">
                <label class="admin-form__label field__label--inline">
                    <input type="checkbox" asp-for="IsActive" />
                    <span>Aktif</span>
                </label>
            </div>

            <div class="admin-form__actions">
                <button type="submit" class="admin-btn admin-btn--primary">Kaydet</button>
                <a href="@Url.Action("Index")" class="admin-btn admin-btn--secondary">İptal</a>
            </div>
        </form>
    </div>
</div>
