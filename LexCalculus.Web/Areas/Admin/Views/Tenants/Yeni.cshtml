@model LexCalculus.Web.Areas.Admin.Models.Tenants.TenantCreateVm

<div class="admin-page">
    <header class="admin-page__header">
        <h1 class="admin-page__title">Yeni Hukuk Bürosu</h1>
        <p class="admin-page__subtitle">
            Bir tenant (hukuk bürosu/baro) oluştur ve owner olarak bir kullanıcı ata.
            Owner'ın hâlihazırda başka bir tenant'a üye olmaması gerekir.
        </p>
    </header>

    <div asp-validation-summary="ModelOnly" class="admin-banner admin-banner--error"></div>

    <div class="admin-form-layout">
        <form method="post" asp-action="Yeni" class="admin-form">
            @Html.AntiForgeryToken()

            <div class="admin-form__field">
                <label class="admin-form__label" asp-for="Name">Ad</label>
                <input class="admin-form__input" asp-for="Name" placeholder="örn. Hukuk Bürosu A" />
                <span asp-validation-for="Name" class="admin-form__error"></span>
            </div>

            <div class="admin-form__field">
                <label class="admin-form__label" asp-for="Slug">Slug</label>
                <input class="admin-form__input" asp-for="Slug" placeholder="boş bırakırsanız otomatik üretilir" />
                <span asp-validation-for="Slug" class="admin-form__error"></span>
                <span class="admin-form__hint">URL'lerde kullanılır. Sadece küçük harf, rakam ve tire.</span>
            </div>

            <div class="admin-form__field">
                <label class="admin-form__label" asp-for="OwnerUserId">Owner</label>
                <select class="admin-form__input" asp-for="OwnerUserId">
                    <option value="">— Seçiniz —</option>
                    @foreach (var u in Model.AvailableOwners)
                    {
                        <option value="@u.Id">@u.Email (@u.UserName)</option>
                    }
                </select>
                <span asp-validation-for="OwnerUserId" class="admin-form__error"></span>
                <span class="admin-form__hint">Sadece henüz bir tenant'a üye olmayan kullanıcılar listelenir.</span>
            </div>

            <div class="admin-form__actions">
                <button type="submit" class="admin-btn admin-btn--primary">Oluştur</button>
                <a href="@Url.Action("Index")" class="admin-btn admin-btn--secondary">İptal</a>
            </div>
        </form>
    </div>
</div>
