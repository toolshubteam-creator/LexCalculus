@page "/uye/{userSlug}/makale/{postSlug}"
@model LexCalculus.Web.Pages.MakaleModel

@section Scripts {
    <script src="~/js/makale-page.js" asp-append-version="true"></script>
    <script src="~/js/report-modal.js" asp-append-version="true"></script>
    <script src="~/js/comment-original.js" asp-append-version="true"></script>
}

<article class="makale">
    @if (Model.IsOwnerPreview)
    {
        <div class="makale__preview-banner" role="status">
            <strong>Önizleme:</strong> Bu makale henüz yayında değil, yalnızca size görünür.
            <a href="/makalelerim/duzenle/@Model.Post.Id">Düzenle</a> ·
            <a href="/makalelerim?tab=taslak">Makalelerim</a>
        </div>
    }
    @if (Model.IsHiddenPreview)
    {
        <div class="makale__preview-banner makale__preview-banner--hidden" role="status">
            <strong>⚠ Yönetim tarafından gizlendi:</strong> Bu içerik şu anda public erişime kapalı;
            sadece sahibi ve yöneticiler bu önizlemeyi görebilir.
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.FeaturedImageAbsoluteUrl))
    {
        <figure class="makale__featured">
            <img src="@Model.FeaturedImageAbsoluteUrl" alt="@Model.Post.Title" />
        </figure>
    }

    <header class="makale__header">
        @if (Model.Post.Category is not null)
        {
            <div class="makale__category">@Model.Post.Category.Name</div>
        }
        <h1 class="makale__title">@Model.Post.Title</h1>

        <div class="makale__meta">
            <div class="makale__author">
                @if (!string.IsNullOrEmpty(Model.AuthorAvatarUrl))
                {
                    <img src="@Model.AuthorAvatarUrl" alt="@Model.AuthorDisplayName"
                         class="makale__author-avatar" />
                }
                else
                {
                    <span class="makale__author-avatar makale__author-avatar--placeholder"
                          aria-hidden="true">
                        @(Model.AuthorDisplayName.Length > 0
                            ? Model.AuthorDisplayName.Substring(0, 1).ToUpperInvariant()
                            : "?")
                    </span>
                }

                @if (!string.IsNullOrEmpty(Model.AuthorSlug))
                {
                    <a href="/uye/@Model.AuthorSlug" class="makale__author-name">@Model.AuthorDisplayName</a>
                }
                else
                {
                    <span class="makale__author-name">@Model.AuthorDisplayName</span>
                }
            </div>

            @if (Model.Post.PublishedAt.HasValue)
            {
                <span class="makale__date">
                    @Model.Post.PublishedAt.Value.ToLocalTime().ToString("d MMMM yyyy")
                </span>
            }

            @if (Model.Post.IsPublished)
            {
                <span class="makale__views">@Model.Post.ViewCount görüntülenme</span>
            }

            @* Faz 4.9 P2 — beğeni butonu (Faz 5.3: hidden preview'da gizli) *@
            @if (Model.Post.IsPublished && !Model.IsHiddenPreview)
            {
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button type="button"
                            class="makale__like @(Model.IsLikedByViewer ? "makale__like--active" : "")"
                            data-post-id="@Model.Post.Id"
                            aria-pressed="@(Model.IsLikedByViewer ? "true" : "false")"
                            aria-label="Beğen">
                        <span class="makale__like-icon" aria-hidden="true">@(Model.IsLikedByViewer ? "❤" : "♡")</span>
                        <span class="makale__like-count" data-like-count>@Model.LikeCount</span>
                        <span class="makale__like-label">beğeni</span>
                    </button>
                }
                else
                {
                    <a href="/Identity/Account/Login?ReturnUrl=@Uri.EscapeDataString($"/uye/{Model.AuthorSlug}/makale/{Model.Post.Slug}")"
                       class="makale__like makale__like--anon"
                       aria-label="Beğenmek için giriş yapın">
                        <span class="makale__like-icon" aria-hidden="true">♡</span>
                        <span class="makale__like-count">@Model.LikeCount</span>
                        <span class="makale__like-label">beğeni</span>
                    </a>
                }
            }
        </div>
    </header>

    <div class="makale__body">
        @* Body, UserPostService.Sanitize ile temizlenmiş — Html.Raw güvenli.
           BodyHtml = sanitize + inline görsel srcset enrichment (Faz 6.8 #18). *@
        @Html.Raw(Model.BodyHtml)
    </div>

    @if (Model.Post.TagLinks is { Count: > 0 })
    {
        <div class="makale__tags" aria-label="Etiketler">
            @foreach (var link in Model.Post.TagLinks)
            {
                <span class="makale-tag-chip">@link.Tag.Name</span>
            }
        </div>
    }

    @* Faz 4.10 P1 — şikayet linki (post için) *@
    @if (Model.CanReportPost)
    {
        <div class="makale__report">
            <button type="button"
                    class="makale__report-link"
                    data-report-target-type="1"
                    data-report-target-id="@Model.Post.Id">
                Şikayet Et
            </button>
        </div>
    }

    <aside class="makale__disclaimer" role="note">
        <strong>Önemli:</strong> Bu içerik tamamen yazarın kişisel görüşü ve
        değerlendirmesidir. Hukuki tavsiye niteliği taşımaz. Spesifik durumunuz
        için lütfen yetkili bir hukuk profesyoneline danışınız.
    </aside>

    @* Faz 4.9 P2 — Yorum bölümü (Faz 5.3: hidden preview'da gizli; taslak'ta zaten yok) *@
    @if (Model.Post.IsPublished && !Model.IsHiddenPreview)
    {
        <section class="yorumlar" id="yorumlar">
            <h2 class="yorumlar__title">
                Yorumlar <span class="yorumlar__count">@Model.CommentCount</span>
            </h2>

            @if (Model.ViewerCanComment)
            {
                <form id="yorum-form" class="yorum-form" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="postId" value="@Model.Post.Id" />
                    <textarea name="body" maxlength="1000"
                              placeholder="Yorumunuzu yazın..."
                              class="yorum-form__textarea"
                              rows="4"
                              aria-label="Yorum içeriği"></textarea>
                    <div class="yorum-form__footer">
                        <span class="yorum-form__counter" data-counter>0 / 1000</span>
                        <button type="submit" class="btn btn--primary">Yorumu Gönder</button>
                    </div>
                    <div class="yorum-form__error" data-error hidden role="alert"></div>
                </form>
            }
            else if (User.Identity?.IsAuthenticated != true)
            {
                <p class="yorum-form__login">
                    Yorum yapmak için
                    <a href="/Identity/Account/Login?ReturnUrl=@Uri.EscapeDataString($"/uye/{Model.AuthorSlug}/makale/{Model.Post.Slug}")">giriş yapın</a>.
                </p>
            }

            @if (Model.Comments.Count > 0)
            {
                <ul class="yorum-list" id="yorum-list">
                    @foreach (var comment in Model.Comments)
                    {
                        <partial name="_PostComment" model="comment" />
                    }
                </ul>
            }
            else
            {
                <p class="yorumlar__empty" id="yorum-list-empty">
                    Henüz yorum yok. İlk yorumu siz yapın.
                </p>
            }
        </section>
    }

    @* Faz 4.10 P1 — şikayet modal'i (login user için; hidden preview'da gizli) *@
    @if (User.Identity?.IsAuthenticated == true && Model.Post.IsPublished && !Model.IsHiddenPreview)
    {
        <partial name="_ReportModal" />
    }

    @if (!string.IsNullOrEmpty(Model.AuthorSlug))
    {
        <footer class="makale__author-footer">
            <h2 class="makale__author-footer-title">Yazar</h2>
            <div class="makale__author-card">
                @if (!string.IsNullOrEmpty(Model.AuthorAvatarUrl))
                {
                    <img src="@Model.AuthorAvatarUrl" alt="@Model.AuthorDisplayName"
                         class="makale__author-card-avatar" />
                }
                else
                {
                    <span class="makale__author-card-avatar makale__author-card-avatar--placeholder"
                          aria-hidden="true">
                        @(Model.AuthorDisplayName.Length > 0
                            ? Model.AuthorDisplayName.Substring(0, 1).ToUpperInvariant()
                            : "?")
                    </span>
                }
                <div class="makale__author-card-info">
                    <a href="/uye/@Model.AuthorSlug" class="makale__author-card-name">@Model.AuthorDisplayName</a>
                    @if (!string.IsNullOrEmpty(Model.AuthorBio))
                    {
                        <p class="makale__author-card-bio">@Model.AuthorBio</p>
                    }
                    <a href="/uye/@Model.AuthorSlug" class="makale__author-card-link">Profili Gör →</a>
                </div>
            </div>
        </footer>
    }
</article>
