@page "/uye/{slug}"
@model LexCalculus.Web.Pages.UyeModel

<section class="uye-profil">
    <header class="uye-profil__header">
        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
        {
            <img src="@Model.AvatarUrl" alt="@Model.DisplayName"
                 class="uye-profil__avatar" />
        }
        else
        {
            <div class="uye-profil__avatar uye-profil__avatar--placeholder"
                 aria-label="@Model.DisplayName">
                @(Model.DisplayName.Length > 0
                    ? Model.DisplayName.Substring(0, 1).ToUpperInvariant()
                    : "?")
            </div>
        }

        <h1 class="uye-profil__name">@Model.DisplayName</h1>

        @if (!Model.IsPublic)
        {
            <p class="uye-profil__hint">Bu profil gizli tutuluyor.</p>
        }
    </header>

    @* Faz 4.2 P3a/3 — bağlantı butonu state-aware *@
    @if (TempData["Success"] is string successMsg)
    {
        <div class="form-section__message form-section__message--success" role="status">@successMsg</div>
    }
    @if (TempData["Error"] is string errorMsg)
    {
        <div class="form-section__message form-section__message--error" role="alert">@errorMsg</div>
    }

    <div class="uye-profil__interaction">
        @if (Model.IsViewerAnonymous)
        {
            <a href="/Identity/Account/Login?ReturnUrl=@Uri.EscapeDataString($"/uye/{Model.Slug}")"
               class="btn btn--primary">
                Bağlantı kurmak için giriş yapın
            </a>
        }
        else if (Model.IsOwnProfile)
        {
            <a href="/profil" class="btn btn--ghost">Profilinizi Düzenle</a>
        }
        else if (Model.ConnectionState is { } state)
        {
            switch (state.State)
            {
                case UserConnectionState.None:
                    <form method="post" asp-page-handler="Connect" class="uye-profil__action-form">
                        <button type="submit" class="btn btn--primary">Bağlantı İste</button>
                    </form>
                    break;

                case UserConnectionState.PendingSent:
                    <span class="uye-profil__connection-status">İstek gönderildi, beklemede</span>
                    <form method="post" asp-page-handler="Cancel" class="uye-profil__action-form">
                        <input type="hidden" name="connectionId" value="@Model.ConnectionId" />
                        <button type="submit" class="btn btn--ghost">İsteği İptal Et</button>
                    </form>
                    break;

                case UserConnectionState.PendingReceived:
                    <span class="uye-profil__connection-status">Size bağlantı isteği gönderildi</span>
                    <form method="post" asp-page-handler="Accept" class="uye-profil__action-form">
                        <input type="hidden" name="connectionId" value="@Model.ConnectionId" />
                        <button type="submit" class="btn btn--primary">Kabul Et</button>
                    </form>
                    <form method="post" asp-page-handler="Reject" class="uye-profil__action-form">
                        <input type="hidden" name="connectionId" value="@Model.ConnectionId" />
                        <button type="submit" class="btn btn--ghost">Reddet</button>
                    </form>
                    break;

                case UserConnectionState.Accepted:
                    <span class="uye-profil__connection-status uye-profil__connection-status--accepted">
                        ✓ Bağlısınız
                    </span>
                    <form method="post" asp-page-handler="Remove" class="uye-profil__action-form">
                        <input type="hidden" name="connectionId" value="@Model.ConnectionId" />
                        <button type="submit" class="btn btn--ghost"
                                onclick="return confirm('Bağlantıyı kaldırmak istediğinizden emin misiniz?')">
                            Bağlantıyı Kaldır
                        </button>
                    </form>
                    break;

                case UserConnectionState.CooldownAfterReject:
                    {
                        var daysLeft = state.CooldownExpiresAt.HasValue
                            ? Math.Max(0, (int)Math.Ceiling((state.CooldownExpiresAt.Value - DateTime.UtcNow).TotalDays))
                            : 0;
                        <p class="uye-profil__connection-status uye-profil__connection-status--cooldown">
                            Bu kullanıcıya yakın zamanda istek gönderdiniz.
                            @if (daysLeft > 0)
                            {
                                <text> @daysLeft gün sonra tekrar deneyebilirsiniz.</text>
                            }
                            else
                            {
                                <text> Yakında tekrar deneyebilirsiniz.</text>
                            }
                        </p>
                    }
                    break;
            }
        }
    </div>

    @if (Model.IsPublic && Model.ConnectionCount > 0)
    {
        <div class="uye-profil__connection-count">
            <span class="uye-profil__connection-count-number">@Model.ConnectionCount</span>
            <span class="uye-profil__connection-count-label">bağlantı</span>
        </div>
    }

    @if (Model.IsPublic)
    {
        <div class="uye-profil__details">
            @if (!string.IsNullOrEmpty(Model.Meslek))
            {
                <p class="uye-profil__meta">
                    <span class="uye-profil__meta-label">Meslek:</span>
                    <span>@Model.Meslek</span>
                </p>
            }

            @if (!string.IsNullOrEmpty(Model.City))
            {
                <p class="uye-profil__meta">
                    <span class="uye-profil__meta-label">Şehir:</span>
                    <span>@Model.City</span>
                </p>
            }

            @if (!string.IsNullOrEmpty(Model.TenantName))
            {
                <p class="uye-profil__meta">
                    <span class="uye-profil__meta-label">Hukuk Bürosu:</span>
                    <span>@Model.TenantName</span>
                </p>
            }

            @if (!string.IsNullOrEmpty(Model.Bio))
            {
                <div class="uye-profil__bio">
                    <h2 class="uye-profil__section-title">Hakkında</h2>
                    <p class="uye-profil__bio-text">@Model.Bio</p>
                </div>
            }
        </div>
    }
</section>
