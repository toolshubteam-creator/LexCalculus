@page "/profil"
@model LexCalculus.Web.Pages.ProfilModel
@{
    ViewData["Title"] = "Profil";
    ViewData["NoIndex"] = true;
}

<div class="form-section form-section--narrow">
    <h1 class="form-section__title">Profil Bilgilerim</h1>

    @if (Model.StatusMessage != null)
    {
        <div class="form-section__message form-section__message--success" role="status">
            @Model.StatusMessage
        </div>
    }

    <div asp-validation-summary="All" class="form-section__message form-section__message--error"></div>

    <form method="post" id="profile-form">
        <div class="field">
            <label class="field__label">E-posta</label>
            <input class="field__input field__input--locked" value="@Model.Email" readonly />
            <span class="field-hint">E-posta adresinizi değiştirmek için yöneticiyle iletişime geçin.</span>
        </div>

        <div class="field">
            <label asp-for="Input.FullName" class="field__label field__label--required">
                Ad-Soyad <span class="required">*</span>
            </label>
            <input asp-for="Input.FullName" class="field__input" maxlength="100" autocomplete="name" aria-required="true" />
            <span asp-validation-for="Input.FullName" class="field-hint"></span>
        </div>

        <div class="field">
            <label asp-for="Input.MeslekTuru" class="field__label">Mesleğiniz</label>
            <select asp-for="Input.MeslekTuru" id="Input_MeslekTuru" class="field__input">
                <option value="">— Belirtmek istemiyorum —</option>
                <option value="1">Avukat</option>
                <option value="2">Hâkim</option>
                <option value="3">Savcı</option>
                <option value="4">Bilirkişi</option>
                <option value="5">Mali Müşavir</option>
                <option value="99">Diğer</option>
            </select>
            <span asp-validation-for="Input.MeslekTuru" class="field-hint"></span>
        </div>

        <div class="field @(Model.Input.MeslekTuru == LexCalculus.Core.Enums.MeslekTuru.Diger ? "" : "is-hidden")"
             data-meslek-diger-wrapper>
            <label asp-for="Input.MeslekTuruDiger" class="field__label">Mesleğinizi yazınız</label>
            <input asp-for="Input.MeslekTuruDiger" class="field__input" maxlength="50" />
            <span asp-validation-for="Input.MeslekTuruDiger" class="field-hint"></span>
        </div>

        <div class="field">
            <label asp-for="Input.BaroNo" class="field__label">Baro/Sicil Numarası</label>
            <input asp-for="Input.BaroNo" class="field__input" maxlength="50" />
            <span asp-validation-for="Input.BaroNo" class="field-hint">Avukat/Hâkim/Savcı/Bilirkişi için sicil veya baro numarası (opsiyonel).</span>
        </div>

        <div class="field">
            <label asp-for="Input.PhoneNumber" class="field__label">Telefon</label>
            <input asp-for="Input.PhoneNumber" class="field__input" type="tel" autocomplete="tel" />
            <span asp-validation-for="Input.PhoneNumber" class="field-hint"></span>
        </div>

        <div class="field">
            <label class="field__label field__label--inline">
                <input type="checkbox" asp-for="Input.NotificationsEmailEnabled" />
                <span>E-posta bildirimleri al</span>
            </label>
            <span class="field-hint">
                Veri güncellemeleri ve hesap bildirimlerini e-posta olarak almak istemiyorsanız bunu kapatabilirsiniz.
            </span>
        </div>

        @* Faz 4.1 P1/3 — Kamuya Açık Profil bölümü *@
        <h2 class="form-section__title form-section__title--sub">Kamuya Açık Profil</h2>
        <p class="field-hint">
            Profilinizi kamuya açtığınızda diğer kullanıcılar sizi <code>/uye/{slug}</code>
            adresinden görebilir. Profil gizli kalsa bile bu bilgileri istediğiniz zaman doldurabilirsiniz.
        </p>

        <div class="field">
            <label class="field__label field__label--inline">
                <input type="checkbox" asp-for="Input.IsPublicProfile" />
                <span>Profilim kamuya açık</span>
            </label>
            <span class="field-hint">
                Açtığınızda profiliniz arama motorlarında görünebilir ve <code>/uye/...</code> URL'inden erişilebilir.
            </span>
        </div>

        @if (Model.HasTenant)
        {
            <div class="field">
                <label class="field__label field__label--inline">
                    <input type="checkbox" asp-for="Input.ShowTenant" />
                    <span>Hukuk büromu profilimde göster</span>
                </label>
                <span class="field-hint">
                    Profil kamuya açıksa hukuk büronuzun adı profil sayfasında görünür.
                </span>
            </div>
        }

        <div class="field">
            <label asp-for="Input.PublicSlug" class="field__label">Profil URL kısayolu</label>
            <input asp-for="Input.PublicSlug" class="field__input" maxlength="100" placeholder="ornek-isim" />
            <span asp-validation-for="Input.PublicSlug" class="field-hint"></span>
            <span class="field-hint">
                Boş bırakırsanız adınızdan otomatik oluşturulur. Sadece küçük harf, rakam ve tire içerebilir.
            </span>
        </div>

        <div class="field">
            <label asp-for="Input.City" class="field__label">Şehir</label>
            <input asp-for="Input.City" class="field__input" maxlength="80" placeholder="İstanbul" />
            <span asp-validation-for="Input.City" class="field-hint"></span>
        </div>

        <div class="field">
            <label asp-for="Input.Bio" class="field__label">Hakkınızda</label>
            <textarea asp-for="Input.Bio" class="field__input" rows="4" maxlength="2000"></textarea>
            <span asp-validation-for="Input.Bio" class="field-hint"></span>
            <span class="field-hint">En fazla 2000 karakter. HTML kabul edilmez.</span>
        </div>

        <div class="form-section__actions">
            <button type="submit" class="btn btn--primary">Kaydet</button>
        </div>
    </form>

    <div class="form-section__cta">
        <a href="/profil/sifre-degistir" class="form-section__cta-link">Şifre değiştir</a>
        &nbsp;·&nbsp;
        <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="form-section__cta-inline-form">
            <button type="submit" class="form-section__cta-link-btn">Çıkış yap</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/register.js" asp-append-version="true"></script>
}
