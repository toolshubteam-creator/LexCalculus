@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.IsHukuku
@model FazlaMesaiInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as FazlaMesaiResult;
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Haftalık 45 saatten fazla çalıştırılan işçinin alacak tespitinde</li>
        <li>Hafta tatili veya ulusal bayramda çalışan işçinin zamlı ücret hesabında</li>
        <li>Bordro denetimlerinde fazla mesai eksikliklerinin tespitinde</li>
        <li>İş davası açılmadan önce alacak hesabının çıkarılmasında</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        Zamanaşımı 5 yıldır (m.32). Yargıtay 9. HD pratiği: aylık brüt / (haftalık saat × 4,33).
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Haftalık 45 saati aşan çalışma fazla mesai sayılır.</strong> 4857 s.K. m.41 uyarınca fazla mesai %50, hafta tatili ve ulusal bayram %100 zamlı ücretlendirilir. Faz 2'de toplulaştırılmış saat girişi yapılır; haftalık dökümlü hesap Faz 5'tedir.
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="FazlaMesai">
        <h2 class="form-section__title">Hesaplama Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field">
            <label asp-for="BrutAylikUcret" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.BrutAylikUcret) <span class="required">*</span>
            </label>
            <input asp-for="BrutAylikUcret" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 30000" />
            <span asp-validation-for="BrutAylikUcret" class="field-hint"></span>
        </div>

        <div class="field-row">
            <div class="field">
                <label asp-for="HaftalikNormalSaat" class="field__label">
                    @Html.DisplayNameFor(m => m.HaftalikNormalSaat)
                </label>
                <input asp-for="HaftalikNormalSaat" class="field__input" type="number" step="1" min="1" max="60" />
                <div class="field-hint">Standart 45 saat. Sözleşme farklı belirlemişse o değer.</div>
            </div>

            <div class="field">
                <label asp-for="HesapTarihi" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.HesapTarihi) <span class="required">*</span>
                </label>
                <input asp-for="HesapTarihi" class="field__input" type="date" />
                <span asp-validation-for="HesapTarihi" class="field-hint"></span>
            </div>
        </div>

        <h3 class="form-section__title form-section__title--sub">Mesai Saatleri</h3>

        <div class="field">
            <label asp-for="FazlaMesaiSaati" class="field__label">
                @Html.DisplayNameFor(m => m.FazlaMesaiSaati) (×1,5)
            </label>
            <input asp-for="FazlaMesaiSaati" class="field__input" type="number" step="1" min="0" placeholder="0" />
            <div class="field-hint">Haftalık 45 saat üzerine geçen mesai saatlerinin toplamı.</div>
        </div>

        <div class="field">
            <label asp-for="HaftaTatiliSaati" class="field__label">
                @Html.DisplayNameFor(m => m.HaftaTatiliSaati) (×2,0)
            </label>
            <input asp-for="HaftaTatiliSaati" class="field__input" type="number" step="1" min="0" placeholder="0" />
        </div>

        <div class="field">
            <label asp-for="BayramSaati" class="field__label">
                @Html.DisplayNameFor(m => m.BayramSaati) (×2,0)
            </label>
            <input asp-for="BayramSaati" class="field__input" type="number" step="1" min="0" placeholder="0" />
        </div>

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Mesai saatlerinizi girip "Hesapla" butonuna basarak fazla mesai alacağınızı görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", new System.Globalization.CultureInfo("tr-TR"))<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/is-hukuku">← İş Hukuku</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
