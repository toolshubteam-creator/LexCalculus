@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.IsHukuku
@model MobbingInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as MobbingResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--warning">
    <strong>Bu araç tahmin amaçlıdır.</strong> Manevi tazminatın <em>yasal bir formülü yoktur</em>; mahkeme takdir hakkına göre karar verir. Burada üretilen aralık, Yargıtay 9. HD emsal kararlarının istatistiksel ortalamasıdır.
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="Mobbing">
        <h2 class="form-section__title">Olay Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field">
            <label asp-for="BrutAylikUcret" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.BrutAylikUcret) <span class="required">*</span>
            </label>
            <input asp-for="BrutAylikUcret" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 30000" />
            <span asp-validation-for="BrutAylikUcret" class="field-hint"></span>
        </div>

        <div class="field-row">
            <div class="field">
                <label asp-for="SureAy" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.SureAy) <span class="required">*</span>
                </label>
                <input asp-for="SureAy" class="field__input" type="number" step="1" min="1" placeholder="örn. 12" />
                <div class="field-hint">Yargıtay genel kabul: minimum 6 ay.</div>
                <span asp-validation-for="SureAy" class="field-hint"></span>
            </div>

            <div class="field">
                <label asp-for="Siddet" class="field__label">
                    @Html.DisplayNameFor(m => m.Siddet)
                </label>
                <select asp-for="Siddet" asp-items="Html.GetEnumSelectList<MobbingSiddeti>()" class="field__input"></select>
            </div>
        </div>

        <div class="field">
            <label asp-for="IsverenTipi" class="field__label">
                @Html.DisplayNameFor(m => m.IsverenTipi)
            </label>
            <select asp-for="IsverenTipi" asp-items="Html.GetEnumSelectList<IsverenKonumu>()" class="field__input"></select>
        </div>

        <div class="field">
            <label class="field__label field__label--checkbox">
                <input asp-for="SaglikRaporu" type="checkbox" />
                <span>@Html.DisplayNameFor(m => m.SaglikRaporu)</span>
            </label>
        </div>

        <div class="field">
            <label class="field__label field__label--checkbox">
                <input asp-for="IstifaSebebi" type="checkbox" />
                <span>@Html.DisplayNameFor(m => m.IstifaSebebi)</span>
            </label>
        </div>

        <button type="submit" class="btn btn--primary btn--block">Tahmini Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Tahmini Aralık</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Bilgileri girip "Tahmini Hesapla" butonuna basarak emsal kararlar tabanlı tahmini görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @if (result.EmsalKarakteristik.Any())
            {
                <div class="result-detail">
                    <h4 class="result-detail__title">Hesaba Giren Düzeltmeler</h4>
                    <div class="result-detail__table">
                        @foreach (var f in result.EmsalKarakteristik)
                        {
                            <div class="result-row">
                                <span class="result-row__key">+</span>
                                <span class="result-row__val">@f</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/is-hukuku">← İş Hukuku</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
