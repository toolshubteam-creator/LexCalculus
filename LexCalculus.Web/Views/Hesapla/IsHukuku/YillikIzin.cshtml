@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.IsHukuku
@model YillikIzinInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as YillikIzinResult;
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>İş sözleşmesi sona eren işçinin kullanmadığı yıllık izinlerinin parasal karşılığında</li>
        <li>Toplu işten çıkarmalarda birikmiş izin alacaklarının tespitinde</li>
        <li>Bilirkişi raporlarında izin hak edişlerinin kontrolünde</li>
        <li>Devir/birleşme durumlarında işçi izin alacağının hesaplanmasında</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        Çalışırken yıllık izin ücreti talep edilemez (m.59); sadece fesih anında.
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Hak kazanılmış izin ücreti, fesih anında ödenir.</strong> Kıdeme göre 14-26 gün arasında değişir (4857 s.K. m.53); kullanılmayan izinler için son ücret üzerinden brüt hesap yapılır, vergi kesintisi uygulanır.
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="YillikIzin">
        <h2 class="form-section__title">Hesaplama Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field-row">
            <div class="field">
                <label asp-for="GirisTarihi" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.GirisTarihi) <span class="required">*</span>
                </label>
                <input asp-for="GirisTarihi" class="field__input" type="date" />
                <span asp-validation-for="GirisTarihi" class="field-hint"></span>
            </div>

            <div class="field">
                <label asp-for="CikisTarihi" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.CikisTarihi) <span class="required">*</span>
                </label>
                <input asp-for="CikisTarihi" class="field__input" type="date" />
                <span asp-validation-for="CikisTarihi" class="field-hint"></span>
            </div>
        </div>

        <div class="field">
            <label asp-for="DogumTarihi" class="field__label">
                @Html.DisplayNameFor(m => m.DogumTarihi)
            </label>
            <input asp-for="DogumTarihi" class="field__input" type="date" />
            <div class="field-hint">18 yaş altı veya 50 yaş üstü işçiler için minimum 20 gün izin uygulanır. Boş bırakılabilir.</div>
        </div>

        <div class="field">
            <label asp-for="BrutAylikUcret" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.BrutAylikUcret) <span class="required">*</span>
            </label>
            <input asp-for="BrutAylikUcret" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 30000" />
            <span asp-validation-for="BrutAylikUcret" class="field-hint"></span>
        </div>

        <div class="field">
            <label asp-for="KullanilanIzinGunu" class="field__label">
                @Html.DisplayNameFor(m => m.KullanilanIzinGunu)
            </label>
            <input asp-for="KullanilanIzinGunu" class="field__input" type="number" step="1" min="0" placeholder="0" />
            <div class="field-hint">İşçinin tüm çalışma süresi boyunca kullandığı toplam yıllık izin günü.</div>
            <span asp-validation-for="KullanilanIzinGunu" class="field-hint"></span>
        </div>

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Formu doldurup "Hesapla" butonuna basarak yıllık izin ücreti hesabını görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", new System.Globalization.CultureInfo("tr-TR"))<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/is-hukuku">← İş Hukuku</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
