@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Gayrimenkul
@model EcrimisilInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as EcrimisilResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Haksız işgal (fuzuli şagil) nedeniyle ecrimisil (haksız işgal tazminatı) davalarında</li>
        <li>Hisseli taşınmazda paydaşlardan birinin taşınmazı tek başına kullanması halinde</li>
        <li>Kira sözleşmesi bitmesine rağmen kullanmaya devam eden için</li>
        <li>İdarenin / üçüncü kişinin taşınmazı izinsiz kullanması durumunda</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        İlk dönem rayiç kira (bilirkişi tespiti) sonraki yıllar için <strong>ÜFE</strong>
        (TÜFE değil) birikimli artışıyla güncellenir.
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Bu hesaplama prensip seviyesinde sonuç verir. Somut davada
    mahkeme/bilirkişi raporu rayiç kira, konum ve çevresel faktörleri değerlendirir.
    Yargıtay 1. HD içtihadına göre ecrimisil, ÜFE artış oranının tamamı yansıtılarak
    bulunan miktardan az olamaz. <strong>Bu sonuç bilirkişi incelemesi yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="Ecrimisil">
        <h2 class="form-section__title">İşgal Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field-row">
            <div class="field">
                <label asp-for="IsgalBaslangic" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.IsgalBaslangic) <span class="required">*</span>
                </label>
                <input asp-for="IsgalBaslangic" class="field__input" type="date" />
                <span asp-validation-for="IsgalBaslangic" class="field-hint"></span>
            </div>
            <div class="field">
                <label asp-for="IsgalBitis" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.IsgalBitis) <span class="required">*</span>
                </label>
                <input asp-for="IsgalBitis" class="field__input" type="date" />
                <span asp-validation-for="IsgalBitis" class="field-hint"></span>
            </div>
        </div>

        <div class="field-row">
            <div class="field">
                <label asp-for="IlkDonemRayicKira" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.IlkDonemRayicKira) <span class="required">*</span>
                </label>
                <input asp-for="IlkDonemRayicKira" class="field__input" type="number" step="0.01" min="0.01" placeholder="örn. 5000" />
                <div class="field-hint">İşgalin ilk yılı için bilirkişinin tespit ettiği rayiç kira.</div>
                <span asp-validation-for="IlkDonemRayicKira" class="field-hint"></span>
            </div>
            <div class="field">
                <label asp-for="DonemTuru" class="field__label">@Html.DisplayNameFor(m => m.DonemTuru)</label>
                <select asp-for="DonemTuru" asp-items="Html.GetEnumSelectList<EcrimisilDonemTuru>()" class="field__input"></select>
                <div class="field-hint">Rayiç kira aylık mı yıllık mı girildi?</div>
            </div>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                İşgal tarihlerini ve ilk dönem rayiç kirayı girip "Hesapla" butonuna basarak ecrimisili görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
                <div class="result-total__sublabel">@result.DonemListesi.Count dönem (yıl)</div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/gayrimenkul">← Gayrimenkul ve Kat Mülkiyeti</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
