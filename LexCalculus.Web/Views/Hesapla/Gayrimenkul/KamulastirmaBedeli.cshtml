@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Gayrimenkul
@model KamulastirmaBedeliInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as KamulastirmaBedeliResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Kamulaştırma bedel tespiti ve tescil davalarında ön değerlendirme</li>
        <li>İdarenin teklif ettiği bedel ile rayiç değer karşılaştırması</li>
        <li>Acele kamulaştırmada (2942 s.K. m.27) bedel tahmini</li>
        <li>Tarım arazisi / gelir getiren taşınmazda gelir kapitalizasyonu</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        İki yöntem: <strong>emsal karşılaştırma</strong> (arsa/mesken/ticari) veya
        <strong>gelir kapitalizasyonu</strong> (tarım/gelir getiren).
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Bu hesaplama prensip seviyesinde sonuç verir. Somut davada
    mahkeme/bilirkişi raporu rayiç değer, konum, çevresel faktörleri değerlendirir.
    Emsal yönteminde objektif değer artırıcı unsur oranı Yargıtay 5. HD içtihadı gereği
    %100'ü aşamaz. <strong>Bu sonuç bilirkişi incelemesi yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="KamulastirmaBedeli">
        <h2 class="form-section__title">Taşınmaz Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field-row">
            <div class="field">
                <label asp-for="TasinmazTuru" class="field__label">@Html.DisplayNameFor(m => m.TasinmazTuru)</label>
                <select asp-for="TasinmazTuru" asp-items="Html.GetEnumSelectList<TasinmazTuru>()" class="field__input"></select>
            </div>
            <div class="field">
                <label asp-for="Yuzolcumu" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.Yuzolcumu) <span class="required">*</span>
                </label>
                <input asp-for="Yuzolcumu" class="field__input" type="number" step="0.01" min="0.01" placeholder="örn. 1000" />
                <span asp-validation-for="Yuzolcumu" class="field-hint"></span>
            </div>
        </div>

        <div class="field">
            <label asp-for="Yontem" class="field__label">@Html.DisplayNameFor(m => m.Yontem)</label>
            <select asp-for="Yontem" asp-items="Html.GetEnumSelectList<KamulastirmaYontemi>()" class="field__input" id="yontem-select" onchange="toggleYontem()"></select>
        </div>

        <fieldset class="form-fieldset" id="emsal-alanlari">
            <h3 class="form-section__title form-section__title--sub">Emsal Karşılaştırma</h3>
            <div class="field">
                <label asp-for="EmsalBirimFiyat" class="field__label">@Html.DisplayNameFor(m => m.EmsalBirimFiyat)</label>
                <input asp-for="EmsalBirimFiyat" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 5000" />
                <span asp-validation-for="EmsalBirimFiyat" class="field-hint"></span>
            </div>
            <div class="field">
                <label asp-for="ObjektifArtisOrani" class="field__label">@Html.DisplayNameFor(m => m.ObjektifArtisOrani)</label>
                <input asp-for="ObjektifArtisOrani" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 30" />
                <div class="field-hint">Yargıtay 5. HD içtihadı: %100 (çarpan 2.0) tavanı uygulanır.</div>
                <span asp-validation-for="ObjektifArtisOrani" class="field-hint"></span>
            </div>
        </fieldset>

        <fieldset class="form-fieldset" id="gelir-alanlari">
            <h3 class="form-section__title form-section__title--sub">Gelir Kapitalizasyonu</h3>
            <div class="field">
                <label asp-for="YillikNetGelir" class="field__label">@Html.DisplayNameFor(m => m.YillikNetGelir)</label>
                <input asp-for="YillikNetGelir" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 60000" />
                <span asp-validation-for="YillikNetGelir" class="field-hint"></span>
            </div>
            <div class="field">
                <label asp-for="KapitalizasyonOrani" class="field__label">@Html.DisplayNameFor(m => m.KapitalizasyonOrani)</label>
                <input asp-for="KapitalizasyonOrani" class="field__input" type="number" step="0.01" min="0.01" placeholder="örn. 6 (boş = %6 varsayılan)" />
                <div class="field-hint">Boş bırakılırsa varsayılan %6 uygulanır. Değer = yıllık net gelir / kapitalizasyon oranı.</div>
                <span asp-validation-for="KapitalizasyonOrani" class="field-hint"></span>
            </div>
        </fieldset>

        <h3 class="form-section__title form-section__title--sub">Yapı (Bina) — Opsiyonel</h3>
        <div class="field">
            <label class="field__label field__label--checkbox">
                <input asp-for="YapiVar" type="checkbox" onchange="toggleYapi()" id="yapi-var" />
                <span>@Html.DisplayNameFor(m => m.YapiVar)</span>
            </label>
        </div>
        <fieldset class="form-fieldset" id="yapi-alanlari">
            <div class="field-row">
                <div class="field">
                    <label asp-for="YapiAlani" class="field__label">@Html.DisplayNameFor(m => m.YapiAlani)</label>
                    <input asp-for="YapiAlani" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 150" />
                    <span asp-validation-for="YapiAlani" class="field-hint"></span>
                </div>
                <div class="field">
                    <label asp-for="YapiBirimMaliyet" class="field__label">@Html.DisplayNameFor(m => m.YapiBirimMaliyet)</label>
                    <input asp-for="YapiBirimMaliyet" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 8000" />
                    <span asp-validation-for="YapiBirimMaliyet" class="field-hint"></span>
                </div>
            </div>
        </fieldset>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Taşınmaz bilgilerini ve değerleme yöntemini girip "Hesapla" butonuna basarak kamulaştırma bedelini görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
                <div class="result-total__sublabel">@result.KullanilanYontem</div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/gayrimenkul">← Gayrimenkul ve Kat Mülkiyeti</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleYontem() {
            var v = document.getElementById('yontem-select').value;
            // Enum: EmsalKarsilastirma=1, GelirKapitalizasyonu=2
            var emsal = (v === '1' || v === 'EmsalKarsilastirma');
            document.getElementById('emsal-alanlari').style.display = emsal ? '' : 'none';
            document.getElementById('gelir-alanlari').style.display = emsal ? 'none' : '';
        }
        function toggleYapi() {
            document.getElementById('yapi-alanlari').style.display =
                document.getElementById('yapi-var').checked ? '' : 'none';
        }
        toggleYontem();
        toggleYapi();
    </script>
}
