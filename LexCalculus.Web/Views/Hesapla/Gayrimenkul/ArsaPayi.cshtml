@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Gayrimenkul
@model ArsaPayiInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as ArsaPayiResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Yeni bir bina için bağımsız bölüm arsa payları belirlenirken</li>
        <li>Kat irtifakı / kat mülkiyeti tescili öncesinde</li>
        <li>Arsa payı düzeltim (iptal) davalarında bilirkişi incelemesinde</li>
        <li>Kat karşılığı inşaat sözleşmelerinde pay tespiti için</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        Yöntem: değer ağırlıklı yüzölçümü (yüzölçümü × kullanım türü katsayısı × kat etkisi katsayısı).
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Paylar 634 s.K. m.3 çerçevesinde standart katsayılarla üretilen bir
    ön değerlendirmedir. Somut olayda mahkeme/bilirkişi incelemesinde rayiç değer, konum, manzara
    gibi etkenler ek katsayılarla değerlendirilebilir. Tapuya tescil edilen nihai paylar
    toplamı tam 1000 olacak şekilde ayarlanır.
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="ArsaPayi">
        <h2 class="form-section__title">Bağımsız Bölümler</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <p class="field-hint">Her bağımsız bölüm için tanım, yüzölçümü, kullanım türü ve bulunduğu kat girilir. (Zemin = 0, bodrum = negatif.)</p>

        <div id="bolum-listesi">
            @for (var i = 0; i < Model.BagimsizBolumler.Count; i++)
            {
                <div class="field-row" data-bolum-index="@i">
                    <div class="field">
                        <label class="field__label">Tanım</label>
                        <input asp-for="BagimsizBolumler[i].Tanim" class="field__input" placeholder="örn. Daire @(i + 1)" />
                    </div>
                    <div class="field">
                        <label class="field__label">Yüzölçümü (m²)</label>
                        <input asp-for="BagimsizBolumler[i].Yuzolcumu" class="field__input" type="number" step="0.01" min="0.01" placeholder="örn. 120" />
                    </div>
                    <div class="field">
                        <label class="field__label">Kullanım Türü</label>
                        <select asp-for="BagimsizBolumler[i].KullanimTuru" asp-items="Html.GetEnumSelectList<KullanimTuru>()" class="field__input"></select>
                    </div>
                    <div class="field">
                        <label class="field__label">Kat</label>
                        <input asp-for="BagimsizBolumler[i].KatNumarasi" class="field__input" type="number" step="1" placeholder="0" />
                    </div>
                </div>
            }
        </div>

        <button type="button" id="add-bolum-btn" class="btn btn--ghost" onclick="addBolum()">+ Yeni Bağımsız Bölüm Ekle</button>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Bağımsız bölümleri girip "Hesapla" butonuna basarak arsa paylarını 1000 üzerinden görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
                <div class="result-total__sublabel">@result.Paylar.Count bağımsız bölüm</div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @if (result.Paylar.Any())
            {
                <div class="result-detail">
                    <h4 class="result-detail__title">Bağımsız Bölüm Detayı</h4>
                    <div class="result-detail__table">
                        @foreach (var p in result.Paylar)
                        {
                            <div class="result-row">
                                <span class="result-row__key">@p.Tanim — @p.Yuzolcumu.ToString("N2", tr) m² (ağırlıklı @p.AgirliklikDeger.ToString("N2", tr))</span>
                                <span class="result-row__val">@p.Pay1000.ToString("N2", tr) / 1000</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/gayrimenkul">← Gayrimenkul ve Kat Mülkiyeti</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function addBolum() {
            var container = document.getElementById('bolum-listesi');
            var index = container.children.length;
            var html =
                '<div class="field-row" data-bolum-index="' + index + '">' +
                  '<div class="field">' +
                    '<label class="field__label">Tanım</label>' +
                    '<input name="BagimsizBolumler[' + index + '].Tanim" class="field__input" placeholder="örn. Daire ' + (index + 1) + '" />' +
                  '</div>' +
                  '<div class="field">' +
                    '<label class="field__label">Yüzölçümü (m²)</label>' +
                    '<input name="BagimsizBolumler[' + index + '].Yuzolcumu" class="field__input" type="number" step="0.01" min="0.01" placeholder="örn. 120" />' +
                  '</div>' +
                  '<div class="field">' +
                    '<label class="field__label">Kullanım Türü</label>' +
                    '<select name="BagimsizBolumler[' + index + '].KullanimTuru" class="field__input">' +
                      '<option value="1">Mesken</option>' +
                      '<option value="2">Dükkan</option>' +
                      '<option value="3">Bodrum</option>' +
                      '<option value="4">Çatı Katı</option>' +
                    '</select>' +
                  '</div>' +
                  '<div class="field">' +
                    '<label class="field__label">Kat</label>' +
                    '<input name="BagimsizBolumler[' + index + '].KatNumarasi" class="field__input" type="number" step="1" placeholder="0" />' +
                  '</div>' +
                '</div>';
            container.insertAdjacentHTML('beforeend', html);
        }
    </script>
}
