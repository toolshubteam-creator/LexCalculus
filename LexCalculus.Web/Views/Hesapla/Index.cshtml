@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Web.Models.Hesapla
@model HesaplaIndexViewModel
@{
    ViewData["Title"] = "Hesaplama Araçları";
}

<section class="hero">
    <div class="hero__eyebrow">Anno MMXXVI</div>
    <h1 class="hero__title">Hukuki <em>hesaplama</em> araçları</h1>
    <p class="hero__lead">Avukat, hâkim ve bilirkişiler için günün verilerine bağlı, şeffaf, kategorize edilmiş hesaplama modülleri.</p>
</section>

<div class="ornament" aria-hidden="true">❦ ❦ ❦</div>

@foreach (var section in Model.Sections)
{
    var cat = section.Category;
    var tools = section.Tools;

    <section class="calc-section">
        <div class="calc-header">
            <h2 class="calc-header__title">@cat.ToDisplayName()</h2>
            <div class="calc-meta">
                <div>@tools.Count ARAÇ</div>
                <div>KATEGORİ <strong>@(((int)cat).ToString("00"))</strong></div>
            </div>
        </div>

        <div class="tools-grid">
            @foreach (var tool in tools)
            {
                var isComingSoon = tool.Status == CalculatorStatus.ComingSoon;

                if (isComingSoon)
                {
                    <div class="tool-card tool-card--coming-soon">
                        <div class="tool-card__num">№ @(tool.DisplayNumber ?? "—") — @cat.ToShortName().ToUpper()</div>
                        <div class="tool-card__title">@tool.Title</div>
                        <div class="tool-card__desc">@tool.ShortDescription</div>
                        <div class="tool-card__meta">@tool.LegalReference · YAKINDA</div>
                    </div>
                }
                else
                {
                    <a href="@tool.UrlPath" class="tool-card tool-card--link">
                        <div class="tool-card__num">№ @(tool.DisplayNumber ?? "—") — @cat.ToShortName().ToUpper()</div>
                        <div class="tool-card__title">@tool.Title</div>
                        <div class="tool-card__desc">@tool.ShortDescription</div>
                        <div class="tool-card__meta">@tool.LegalReference · AKTİF</div>
                    </a>
                }
            }
        </div>
    </section>
}
