@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Ticaret
@model SozlesmeCezasiInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as SozlesmeCezasiResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Sabit tutar veya yüzde oran şeklinde ceza şartının hesaplanmasında</li>
        <li>Cezanın asıl borca oranına göre fahiş değerlendirme bandında</li>
        <li>Hâkim TBK m.182 ile indirim olasılığının değerlendirilmesinde</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;" id="ceza-sekli-bilgi">
        Sabit tutar: girilen TL kadar; yüzde oran: asıl borç × oran.
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Bu hesap TBK m.179-182 sözleşme cezası formülünü uygular. Hâkim
    TBK m.182 gereği cezayı hakkaniyete uygun olarak azaltabilir; bu hesabın "fahiş" bandı
    sadece indikatördür. İfa + ceza ilişkisi (m.180) ayrıca değerlendirilir; tacirler için
    m.182 indirimi farklı yorumlanır.
    <strong>Bu sonuç mahkeme kararı yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="SozlesmeCezasi">
        <h2 class="form-section__title">Ceza Şartı Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field">
            <label asp-for="AsilBorc" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.AsilBorc) <span class="required">*</span>
            </label>
            <input asp-for="AsilBorc" class="field__input" type="number" step="0.01" min="0.01" placeholder="örn. 100000" />
            <span asp-validation-for="AsilBorc" class="field-hint"></span>
        </div>

        <div class="field-row">
            <div class="field">
                <label asp-for="CezaSekli" class="field__label">@Html.DisplayNameFor(m => m.CezaSekli)</label>
                <select asp-for="CezaSekli" asp-items="Html.GetEnumSelectList<CezaSekli>()" class="field__input" id="cezaSekli"></select>
            </div>
            <div class="field">
                <label asp-for="IhlalTuru" class="field__label">@Html.DisplayNameFor(m => m.IhlalTuru)</label>
                <select asp-for="IhlalTuru" asp-items="Html.GetEnumSelectList<IhlalTuru>()" class="field__input"></select>
            </div>
        </div>

        <div class="field" data-group="sabit">
            <label asp-for="BelirlenenCeza" class="field__label">@Html.DisplayNameFor(m => m.BelirlenenCeza)</label>
            <input asp-for="BelirlenenCeza" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 50000" />
            <span asp-validation-for="BelirlenenCeza" class="field-hint"></span>
        </div>

        <div class="field" data-group="yuzde">
            <label asp-for="BelirlenenOran" class="field__label">@Html.DisplayNameFor(m => m.BelirlenenOran)</label>
            <input asp-for="BelirlenenOran" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 50" />
            <span asp-validation-for="BelirlenenOran" class="field-hint"></span>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Asıl borç, ceza şekli ve değerini girip "Hesapla" butonuna basarak hesaplanan
                cezayı ve fahiş değerlendirmesini görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/ticaret">← Ticaret Hukuku</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var sel = document.getElementById('cezaSekli');
            var bilgi = document.getElementById('ceza-sekli-bilgi');
            function show(group, vis) {
                var el = document.querySelector('[data-group="' + group + '"]');
                if (el) el.style.display = vis ? '' : 'none';
            }
            function refresh() {
                var sabit = sel.value === '1';
                show('sabit', sabit);
                show('yuzde', !sabit);
                bilgi.textContent = sabit
                    ? 'Sabit tutar: girilen TL kadar.'
                    : 'Yüzde oran: asıl borç × oran (%).';
            }
            sel.addEventListener('change', refresh);
            refresh();
        })();
    </script>
}
