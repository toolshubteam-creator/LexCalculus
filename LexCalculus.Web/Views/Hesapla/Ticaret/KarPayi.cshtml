@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Ticaret
@model KarPayiInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as KarPayiResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Anonim Şirket'te yıl sonu kâr dağıtım önerisinin hazırlanmasında</li>
        <li>Yasal yedek akçe (m.519/1 — %5, sermaye %20 cap) ayrılmasında</li>
        <li>Birinci (m.508/1 — sermaye %5) ve ikinci temettünün belirlenmesinde</li>
        <li>Opsiyonel özel yedek akçenin (m.519/2 — kalan × %10) ayrılmasında</li>
    </ul>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Bu hesap TTK m.508 + m.519 kâr dağıtım formülünü uygular. Genel
    kurul kararı, özel yedek akçe (m.521), kâr dağıtımına katılma esasları (m.503), imtiyazlı
    pay sahiplerinin hakları (m.478) ayrıca değerlendirilir.
    <strong>Bu sonuç genel kurul kararı yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="KarPayi">
        <h2 class="form-section__title">Kâr Dağıtım Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field-row">
            <div class="field">
                <label asp-for="NetKar" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.NetKar) <span class="required">*</span>
                </label>
                <input asp-for="NetKar" class="field__input" type="number" step="0.01" min="0.01" placeholder="örn. 1000000" />
                <span asp-validation-for="NetKar" class="field-hint"></span>
            </div>
            <div class="field">
                <label asp-for="KanuniSermaye" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.KanuniSermaye) <span class="required">*</span>
                </label>
                <input asp-for="KanuniSermaye" class="field__input" type="number" step="0.01" min="0.01" placeholder="örn. 5000000" />
                <span asp-validation-for="KanuniSermaye" class="field-hint"></span>
            </div>
        </div>

        <div class="field">
            <label asp-for="MevcutYasalYedek" class="field__label">@Html.DisplayNameFor(m => m.MevcutYasalYedek)</label>
            <input asp-for="MevcutYasalYedek" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 200000" />
            <span asp-validation-for="MevcutYasalYedek" class="field-hint"></span>
        </div>

        <div class="field">
            <label class="field__label">
                <input asp-for="OzelYedekUygulanir" type="checkbox" /> @Html.DisplayNameFor(m => m.OzelYedekUygulanir)
            </label>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Net kâr ve kanuni sermayeyi girip "Hesapla" butonuna basarak yasal yedek, temettü
                ve toplam dağıtım önerisini görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/ticaret">← Ticaret Hukuku</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
