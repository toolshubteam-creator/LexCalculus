@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Ticaret
@model SirketTasfiyePayiInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as SirketTasfiyePayiResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Anonim Şirket (TTK m.543) veya Limited Şirket (m.642) tasfiyesinde</li>
        <li>Net tasfiye varlığı (varlık − borç) üzerinden ortaklara dağıtım</li>
        <li>İmtiyazlı pay sahiplerinin esas sözleşme oranı + standart ortaklara eşit</li>
    </ul>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Bu hesap TTK m.543/642 tasfiye paylaşım formülünü uygular.
    Tasfiye memuru raporu, alacaklı önceliği, vergi kesintileri ve son bilanço onayı
    ayrı değerlendirilir. İmtiyazlı pay sahipleri esas sözleşmeye göre belirlenir.
    <strong>Bu sonuç tasfiye memuru raporu yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="SirketTasfiyePayi">
        <h2 class="form-section__title">Tasfiye Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field-row">
            <div class="field">
                <label asp-for="ToplamVarlik" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.ToplamVarlik) <span class="required">*</span>
                </label>
                <input asp-for="ToplamVarlik" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 5000000" />
                <span asp-validation-for="ToplamVarlik" class="field-hint"></span>
            </div>
            <div class="field">
                <label asp-for="ToplamBorc" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.ToplamBorc) <span class="required">*</span>
                </label>
                <input asp-for="ToplamBorc" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 1500000" />
                <span asp-validation-for="ToplamBorc" class="field-hint"></span>
            </div>
        </div>

        <div class="field">
            <label asp-for="StandartOrtakSayisi" class="field__label">@Html.DisplayNameFor(m => m.StandartOrtakSayisi)</label>
            <input asp-for="StandartOrtakSayisi" class="field__input" type="number" step="1" min="0" max="10000" />
            <span asp-validation-for="StandartOrtakSayisi" class="field-hint"></span>
        </div>

        <h3 class="form-section__subtitle">İmtiyazlı Pay Sahipleri (opsiyonel)</h3>
        <p class="field-hint">Esas sözleşmede tanımlı imtiyazlı pay sahiplerine net varlık üzerinden ayrı oran uygulanır.</p>
        <div id="imtiyaz-listesi">
            @for (var i = 0; i < Model.ImtiyazliPaylar.Count; i++)
            {
                <div class="field-row" data-imtiyaz-index="@i">
                    <div class="field">
                        <label class="field__label">Ortak Adı</label>
                        <input asp-for="ImtiyazliPaylar[i].OrtakAdi" class="field__input" placeholder="örn. A Ortağı" />
                    </div>
                    <div class="field">
                        <label class="field__label">Pay Adedi</label>
                        <input asp-for="ImtiyazliPaylar[i].PayAdedi" class="field__input" type="number" step="1" min="0" />
                    </div>
                    <div class="field">
                        <label class="field__label">İmtiyaz Oranı (%)</label>
                        <input asp-for="ImtiyazliPaylar[i].ImtiyazOraniYuzde" class="field__input" type="number" step="0.01" min="0" max="100" placeholder="örn. 10" />
                    </div>
                </div>
            }
        </div>
        <button type="button" class="btn btn--ghost" onclick="addImtiyaz()">+ İmtiyazlı Pay Ekle</button>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Varlık, borç ve ortak bilgilerini girip "Hesapla" butonuna basarak net tasfiye
                varlığı ve pay dağılımını görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/ticaret">← Ticaret Hukuku</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function addImtiyaz() {
            var c = document.getElementById('imtiyaz-listesi');
            var i = c.children.length;
            var html =
                '<div class="field-row" data-imtiyaz-index="' + i + '">' +
                  '<div class="field"><label class="field__label">Ortak Adı</label>' +
                    '<input name="ImtiyazliPaylar[' + i + '].OrtakAdi" class="field__input" placeholder="örn. A Ortağı" /></div>' +
                  '<div class="field"><label class="field__label">Pay Adedi</label>' +
                    '<input name="ImtiyazliPaylar[' + i + '].PayAdedi" class="field__input" type="number" step="1" min="0" /></div>' +
                  '<div class="field"><label class="field__label">İmtiyaz Oranı (%)</label>' +
                    '<input name="ImtiyazliPaylar[' + i + '].ImtiyazOraniYuzde" class="field__input" type="number" step="0.01" min="0" max="100" /></div>' +
                '</div>';
            c.insertAdjacentHTML('beforeend', html);
        }
    </script>
}
