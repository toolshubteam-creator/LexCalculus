@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Web.Models.Hesapla
@model HesaplaCategoryViewModel

<section class="hero">
    <div class="hero__eyebrow">— Kategori @(((int)Model.Category).ToString("00")) —</div>
    <h1 class="hero__title">@Model.DisplayName <em>hesaplama</em> araçları</h1>
    <p class="hero__lead">@Model.Tools.Count araç bu kategoride yer alıyor. Her araç güncel mevzuat parametrelerini referans alır.</p>
</section>

<div class="ornament" aria-hidden="true">❦ ❦ ❦</div>

<div class="tools-grid">
    @foreach (var tool in Model.Tools)
    {
        var isComingSoon = tool.Status == CalculatorStatus.ComingSoon;

        if (isComingSoon)
        {
            <div class="tool-card tool-card--coming-soon">
                <div class="tool-card__num">№ @(tool.DisplayNumber ?? "—")</div>
                <div class="tool-card__title">@tool.Title</div>
                <div class="tool-card__desc">@tool.ShortDescription</div>
                <div class="tool-card__meta">@tool.LegalReference · YAKINDA</div>
            </div>
        }
        else
        {
            <a href="@tool.UrlPath" class="tool-card tool-card--link">
                <div class="tool-card__num">№ @(tool.DisplayNumber ?? "—")</div>
                <div class="tool-card__title">@tool.Title</div>
                <div class="tool-card__desc">@tool.ShortDescription</div>
                <div class="tool-card__meta">@tool.LegalReference · AKTİF</div>
            </a>
        }
    }
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla">← Tüm kategoriler</a>
</div>
