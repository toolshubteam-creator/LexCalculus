@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.VergiIdare
@model VergiCezasiInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as VergiCezasiResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Vergi ziyaı (m.341 — %50) veya kaçakçılık (m.359 — %100) cezasının tespitinde</li>
        <li>Usulsüzlük (m.352) maktu cezasının raporlanmasında</li>
        <li>Vade-ödeme arası gecikme faizi (m.112) veya gecikme zammı (6183 m.51) hesabında</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;" id="ceza-bilgi">
        Vergi ziyaı: asıl × %50.
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Bu hesap 213 s.K. ceza ve gecikme faiz formüllerini uygular.
    Pişmanlık (m.371), uzlaşma (m.376), ödeme planı ve indirim hakları ayrıca değerlendirilir.
    Aylık oranlar TCMB/Maliye Bakanlığı referansına bağlıdır; fiili borç bakiyesi vergi
    dairesinden teyit alınmalıdır.
    <strong>Bu sonuç vergi dairesi takip tutarı yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="VergiCezasi">
        <h2 class="form-section__title">Vergi ve Ceza Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field">
            <label asp-for="AsilVergi" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.AsilVergi) <span class="required">*</span>
            </label>
            <input asp-for="AsilVergi" class="field__input" type="number" step="0.01" min="0.01" placeholder="örn. 100000" />
            <span asp-validation-for="AsilVergi" class="field-hint"></span>
        </div>

        <div class="field-row">
            <div class="field">
                <label asp-for="VadeTarihi" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.VadeTarihi) <span class="required">*</span>
                </label>
                <input asp-for="VadeTarihi" class="field__input" type="date" />
                <span asp-validation-for="VadeTarihi" class="field-hint"></span>
            </div>
            <div class="field">
                <label asp-for="OdemeTarihi" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.OdemeTarihi) <span class="required">*</span>
                </label>
                <input asp-for="OdemeTarihi" class="field__input" type="date" />
                <span asp-validation-for="OdemeTarihi" class="field-hint"></span>
            </div>
        </div>

        <div class="field-row">
            <div class="field">
                <label asp-for="CezaTuru" class="field__label">@Html.DisplayNameFor(m => m.CezaTuru)</label>
                <select asp-for="CezaTuru" asp-items="Html.GetEnumSelectList<VergiCezaTuru>()" class="field__input" id="cezaTuru"></select>
            </div>
            <div class="field">
                <label asp-for="FaizTuru" class="field__label">@Html.DisplayNameFor(m => m.FaizTuru)</label>
                <select asp-for="FaizTuru" asp-items="Html.GetEnumSelectList<FaizTuru>()" class="field__input"></select>
            </div>
        </div>

        <div class="field" data-group="usulsuzluk">
            <label asp-for="UsulsuzlukTutari" class="field__label">@Html.DisplayNameFor(m => m.UsulsuzlukTutari)</label>
            <input asp-for="UsulsuzlukTutari" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 5000" />
            <span asp-validation-for="UsulsuzlukTutari" class="field-hint"></span>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Asıl vergi, vade ve ödeme tarihlerini girip "Hesapla" butonuna basarak ceza,
                gecikme faizi ve toplam ödenecek tutarı görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/vergi-idare">← Vergi ve İdare</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var sel = document.getElementById('cezaTuru');
            var info = document.getElementById('ceza-bilgi');
            var usulsuz = document.querySelector('[data-group="usulsuzluk"]');
            function refresh() {
                switch (sel.value) {
                    case '1':
                        info.textContent = 'Vergi ziyaı: asıl × %50.';
                        usulsuz.style.display = 'none';
                        break;
                    case '2':
                        info.textContent = 'Kaçakçılık: asıl × %100.';
                        usulsuz.style.display = 'none';
                        break;
                    case '3':
                        info.textContent = 'Usulsüzlük: maktu — alttaki alanda tutar belirtin.';
                        usulsuz.style.display = '';
                        break;
                }
            }
            sel.addEventListener('change', refresh);
            refresh();
        })();
    </script>
}
