@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.VergiIdare
@model TapuHarciInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as TapuHarciResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Gayrimenkul devrinde tapu harcının (alıcı %2 + satıcı %2) hesabında</li>
        <li>Yalnız alıcı veya yalnız satıcı yükümlülüğünün ayrıştırılmasında</li>
        <li>2026 oranı: 492 s.K. Tapu ve Kadastro Harçları Tarifesi</li>
    </ul>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Bu hesap 492 s.K. Harçlar Kanunu Tapu ve Kadastro Harçları
    Tarifesini 2026 oranıyla uygular. İndirimli oranlar (kentsel dönüşüm, sosyal konut,
    ilk konut alımı vb.) ayrıca değerlendirilir. KDV (taşınmaz türüne göre %1 veya %10)
    ve döner sermaye ücreti ayrı hesaplanır.
    <strong>Bu sonuç tapu müdürlüğünce tahakkuk ettirilen kesin tutar yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="TapuHarci">
        <h2 class="form-section__title">Tapu Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field-row">
            <div class="field">
                <label asp-for="SatisDegeri" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.SatisDegeri) <span class="required">*</span>
                </label>
                <input asp-for="SatisDegeri" class="field__input" type="number" step="0.01" min="0.01" placeholder="örn. 1000000" />
                <span asp-validation-for="SatisDegeri" class="field-hint"></span>
            </div>
            <div class="field">
                <label asp-for="KisiBasi" class="field__label">@Html.DisplayNameFor(m => m.KisiBasi)</label>
                <select asp-for="KisiBasi" asp-items="Html.GetEnumSelectList<TapuHarcKisi>()" class="field__input"></select>
            </div>
        </div>

        <div class="field">
            <label asp-for="AsOfDate" class="field__label">@Html.DisplayNameFor(m => m.AsOfDate)</label>
            <input asp-for="AsOfDate" class="field__input" type="date" />
            <p class="field-hint">Boş bırakılırsa bugün kabul edilir.</p>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Satış değerini ve harç yükümlüsünü seçip "Hesapla" butonuna basarak alıcı/satıcı
                tapu harcı tutarını görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/vergi-idare">← Vergi ve İdare</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
