@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Faiz
@using LexCalculus.Core.Enums
@model KiraArtisiInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as KiraArtisiResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Konut veya çatılı işyeri kira sözleşmesinin yıllık yenileme döneminde</li>
        <li>Sözleşmedeki artış oranının yasal üst sınırı aşıp aşmadığının tespitinde</li>
        <li>Kira tespit davalarında TÜFE üst sınırının hesaplanmasında</li>
        <li>Geçmiş döneme ait kira artışlarının yasal kontrolünde (zamanaşımı 5 yıl)</li>
    </ul>
</div>

<div class="info-box info-box--warning">
    <strong>Hukuki Uyarılar:</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li><strong>TBK m.344/1:</strong> Yenilenen kira dönemlerinde TÜFE 12 aylık ortalama üst sınırdır.</li>
        <li><strong>m.344 emredici:</strong> Sözleşmede TÜFE'den yüksek oran yazılı olsa dahi yasal sınır uygulanır; "TEFE/TÜFE ortalaması" gibi formüller geçersizdir.</li>
        <li><strong>Geçici %25 sınırı:</strong> 11.06.2022-01.07.2024 arası yenilenen konut sözleşmelerinde azami %25 (çatılı işyeri hariç).</li>
        <li><strong>5 yıl kuralı (m.344/3):</strong> Süresi 5 yılı aşan sözleşmelerde kira tespit davası açılabilir.</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        TÜFE seed verisi: 2020 Aralık - 2026 Mart (kaynak: Legalbank/TÜİK). Sistemde olmayan aylar için Override alanını kullanın.
    </div>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="KiraArtisi">
        <h2 class="form-section__title">Kira & Tarih</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field">
            <label asp-for="MevcutKira" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.MevcutKira) <span class="required">*</span>
            </label>
            <input asp-for="MevcutKira" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 15000" />
            <span asp-validation-for="MevcutKira" class="field-hint"></span>
        </div>

        <div class="field">
            <label asp-for="YenilenmeTarihi" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.YenilenmeTarihi) <span class="required">*</span>
            </label>
            <input asp-for="YenilenmeTarihi" class="field__input" type="date" />
            <span asp-validation-for="YenilenmeTarihi" class="field-hint"></span>
            <div class="field-hint">Sözleşmenin yenilendiği tarih. TBK m.344/1 uyarınca bu tarihten BİR ÖNCEKİ ayın TÜFE 12 ay ortalaması kullanılır.</div>
        </div>

        <div class="field">
            <label asp-for="MulkTipi" class="field__label">
                @Html.DisplayNameFor(m => m.MulkTipi)
            </label>
            <select asp-for="MulkTipi" asp-items="Html.GetEnumSelectList<MulkTipi>()" class="field__input"></select>
            <div class="field-hint">11.06.2022-01.07.2024 arası %25 sınırı yalnızca konut için geçerliydi.</div>
        </div>

        <h3 class="form-section__title form-section__title--sub">Opsiyonel Alanlar</h3>

        <div class="field">
            <label asp-for="SozlesmeOrani" class="field__label">
                @Html.DisplayNameFor(m => m.SozlesmeOrani)
            </label>
            <input asp-for="SozlesmeOrani" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 25" />
            <span asp-validation-for="SozlesmeOrani" class="field-hint"></span>
            <div class="field-hint">Sözleşmede yazılı artış oranı. Boş bırakılırsa TÜFE üst sınırı uygulanır. Doluysa: min(sözleşme, TÜFE).</div>
        </div>

        <div class="field">
            <label asp-for="TUFEOverride" class="field__label">
                @Html.DisplayNameFor(m => m.TUFEOverride)
            </label>
            <input asp-for="TUFEOverride" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 32.82" />
            <span asp-validation-for="TUFEOverride" class="field-hint"></span>
            <div class="field-hint">Sistemde olmayan ay için manuel TÜFE girişi. data.tuik.gov.tr'den doğrulayın.</div>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Mevcut kira bedelini, yenileme tarihini ve mülk tipini girip "Hesapla" butonuna basarak yeni kira bedelini ve yasal üst sınırı hesaplayabilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
                <div class="result-total__sublabel">@result.UygulanacakOranAciklama</div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/faiz">← Faiz</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
