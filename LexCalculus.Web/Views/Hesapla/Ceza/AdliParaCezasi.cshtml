@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Ceza
@model AdliParaCezasiInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as AdliParaCezasiResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Direkt adli para cezasında (gün sayısı × günlük miktar, TCK m.52/1)</li>
        <li>Hapis cezasının adli paraya çevrimi (TCK m.50/1 atfı)</li>
        <li>Günlük miktar 20-100 TL bandı (TCK m.52/2 sınırı)</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        Hesap türünü seçtiğinizde ilgili alanlar görünür.
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Bu hesap TCK m.52 formülünü uygular. Günlük miktar (20-100 TL
    bandı) mahkeme takdiridir; sanığın ekonomik durumu, suçun ağırlığı gibi faktörler
    değerlendirilir. <strong>Bu sonuç mahkeme kararı yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="AdliParaCezasi">
        <h2 class="form-section__title">Adli Para Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field">
            <label asp-for="HesapTuru" class="field__label">@Html.DisplayNameFor(m => m.HesapTuru)</label>
            <select asp-for="HesapTuru" asp-items="Html.GetEnumSelectList<AdliParaHesapTuru>()" class="field__input" id="hesapTuru"></select>
        </div>

        <div data-group="direkt">
            <div class="field-row">
                <div class="field">
                    <label asp-for="GunSayisi" class="field__label">@Html.DisplayNameFor(m => m.GunSayisi)</label>
                    <input asp-for="GunSayisi" class="field__input" type="number" step="1" min="5" max="730" placeholder="örn. 90" />
                    <span asp-validation-for="GunSayisi" class="field-hint"></span>
                </div>
                <div class="field">
                    <label asp-for="GunlukMiktar" class="field__label">@Html.DisplayNameFor(m => m.GunlukMiktar)</label>
                    <input asp-for="GunlukMiktar" class="field__input" type="number" step="0.01" min="20" max="100" placeholder="örn. 50" />
                    <span asp-validation-for="GunlukMiktar" class="field-hint"></span>
                </div>
            </div>
        </div>

        <div data-group="cevrim">
            <div class="field-row">
                <div class="field">
                    <label asp-for="HapisGun" class="field__label">@Html.DisplayNameFor(m => m.HapisGun)</label>
                    <input asp-for="HapisGun" class="field__input" type="number" step="1" min="1" placeholder="örn. 180" />
                    <span asp-validation-for="HapisGun" class="field-hint"></span>
                </div>
                <div class="field">
                    <label asp-for="CevrimGunlukMiktar" class="field__label">@Html.DisplayNameFor(m => m.CevrimGunlukMiktar)</label>
                    <input asp-for="CevrimGunlukMiktar" class="field__input" type="number" step="0.01" min="20" max="100" placeholder="örn. 50" />
                    <span asp-validation-for="CevrimGunlukMiktar" class="field-hint"></span>
                </div>
            </div>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Hesap türünü ve ilgili alanları girip "Hesapla" butonuna basarak toplam adli para
                cezasını görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(result.UyariMesaji))
            {
                <div class="result-note">@result.UyariMesaji</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/ceza">← Ceza Hukuku ve İnfaz</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var sel = document.getElementById('hesapTuru');
            function show(group, vis) {
                var el = document.querySelector('[data-group="' + group + '"]');
                if (el) el.style.display = vis ? '' : 'none';
            }
            function refresh() {
                var direkt = sel.value === '1';
                show('direkt', direkt);
                show('cevrim', !direkt);
            }
            sel.addEventListener('change', refresh);
            refresh();
        })();
    </script>
}
