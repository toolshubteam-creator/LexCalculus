@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Ceza
@model CezaErtelemeInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as CezaErtelemeResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Verilen hapis cezasının TCK m.51 erteleme koşullarını sağlayıp sağlamadığı kontrolünde</li>
        <li>Üst sınır testinde (yetişkin 2 yıl / 18 yaş altı çocuk 3 yıl)</li>
        <li>Erteleme süresinin (1-3 yıl) bitiş tarihi ve varsa denetimli serbestlik bitişinde</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        Ceza türünü seçtiğinizde uygun üst sınır otomatik gösterilir.
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Bu hesap TCK m.51 formel koşullarını kontrol eder. Mahkemenin
    "sanığın yeniden suç işlemeyeceği kanaati" gibi takdir yetkisi (m.51/1 son cümle) ve
    sanığın geçmişi, suçun niteliği gibi faktörler ayrıca değerlendirilir.
    <strong>Bu sonuç mahkeme kararı yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="CezaErteleme">
        <h2 class="form-section__title">Ceza Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field-row">
            <div class="field">
                <label asp-for="VerilenCezaGun" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.VerilenCezaGun) <span class="required">*</span>
                </label>
                <input asp-for="VerilenCezaGun" class="field__input" type="number" step="1" min="1" placeholder="örn. 365" />
                <span asp-validation-for="VerilenCezaGun" class="field-hint"></span>
                <p class="field-hint" id="ceza-limit-bilgi">Yetişkin için üst sınır: 730 gün (2 yıl).</p>
            </div>
            <div class="field">
                <label asp-for="CezaTuru" class="field__label">@Html.DisplayNameFor(m => m.CezaTuru)</label>
                <select asp-for="CezaTuru" asp-items="Html.GetEnumSelectList<CezaTuru>()" class="field__input" id="cezaTuru"></select>
            </div>
        </div>

        <div class="field-row">
            <div class="field">
                <label asp-for="ErtelemeSuresi" class="field__label">@Html.DisplayNameFor(m => m.ErtelemeSuresi)</label>
                <select asp-for="ErtelemeSuresi" asp-items="Html.GetEnumSelectList<ErtelemeSuresi>()" class="field__input"></select>
            </div>
            <div class="field">
                <label asp-for="KararTarihi" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.KararTarihi) <span class="required">*</span>
                </label>
                <input asp-for="KararTarihi" class="field__input" type="date" />
                <span asp-validation-for="KararTarihi" class="field-hint"></span>
            </div>
        </div>

        <div class="field">
            <label class="field__label">
                <input asp-for="AdliSicilTemiz" type="checkbox" /> @Html.DisplayNameFor(m => m.AdliSicilTemiz)
            </label>
        </div>

        <div class="field">
            <label asp-for="DenetimliSerbestlikAy" class="field__label">
                @Html.DisplayNameFor(m => m.DenetimliSerbestlikAy)
            </label>
            <input asp-for="DenetimliSerbestlikAy" class="field__input" type="number" step="1" min="0" max="60" placeholder="örn. 12" />
            <span asp-validation-for="DenetimliSerbestlikAy" class="field-hint"></span>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Ceza süresi, türü ve karar tarihini girip "Hesapla" butonuna basarak erteleme
                koşullarının sağlanıp sağlanmadığını ve erteleme bitiş tarihini görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N0", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/ceza">← Ceza Hukuku ve İnfaz</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var sel = document.getElementById('cezaTuru');
            var info = document.getElementById('ceza-limit-bilgi');
            function refresh() {
                switch (sel.value) {
                    case '1':
                        info.textContent = 'Yetişkin için üst sınır: 730 gün (2 yıl).';
                        break;
                    case '2':
                        info.textContent = '18 yaş altı çocuk için üst sınır: 1095 gün (3 yıl).';
                        break;
                    case '3':
                        info.textContent = 'Adli para cezası TCK m.51 erteleme kapsamı dışındadır.';
                        break;
                }
            }
            sel.addEventListener('change', refresh);
            refresh();
        })();
    </script>
}
