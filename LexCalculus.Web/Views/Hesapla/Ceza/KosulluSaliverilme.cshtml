@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Ceza
@model KosulluSaliverilmeInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as KosulluSaliverilmeResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Şartlı tahliye tarihinin belirlenmesinde (mahkumiyet × suç tipi oranı)</li>
        <li>Tutukluluk mahsubunun infaz süresine yansıtılmasında</li>
        <li>Belirli bir referans tarihe göre kalan gün sayısının görülmesinde</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;" id="suc-oran-bilgi">
        Suç tipi: Genel — oran 2/3 (%66,67).
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Bu hesap 5275 s.K. m.107 oranlarını "iyi hal varsayımıyla" uygular.
    İnfaz hâkimi iyi hal takdir yetkisi kullanır; gerçek tahliye tarihi cezaevi kayıtlarına,
    denetim raporlarına ve disiplin cezası durumuna göre değişebilir.
    <strong>Bu sonuç infaz hâkimi kararı veya cezaevi kayıtları yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="KosulluSaliverilme">
        <h2 class="form-section__title">Mahkumiyet Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field-row">
            <div class="field">
                <label asp-for="MahkumiyetGun" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.MahkumiyetGun) <span class="required">*</span>
                </label>
                <input asp-for="MahkumiyetGun" class="field__input" type="number" step="1" min="1" placeholder="örn. 2190 (6 yıl)" />
                <span asp-validation-for="MahkumiyetGun" class="field-hint"></span>
            </div>
            <div class="field">
                <label asp-for="CezaevineGirisTarihi" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.CezaevineGirisTarihi) <span class="required">*</span>
                </label>
                <input asp-for="CezaevineGirisTarihi" class="field__input" type="date" />
                <span asp-validation-for="CezaevineGirisTarihi" class="field-hint"></span>
            </div>
        </div>

        <div class="field-row">
            <div class="field">
                <label asp-for="SucTipi" class="field__label">@Html.DisplayNameFor(m => m.SucTipi)</label>
                <select asp-for="SucTipi" asp-items="Html.GetEnumSelectList<SucTipi>()" class="field__input" id="sucTipi"></select>
            </div>
            <div class="field">
                <label asp-for="TutuklulukGun" class="field__label">@Html.DisplayNameFor(m => m.TutuklulukGun)</label>
                <input asp-for="TutuklulukGun" class="field__input" type="number" step="1" min="0" placeholder="örn. 200" />
                <span asp-validation-for="TutuklulukGun" class="field-hint"></span>
            </div>
        </div>

        <div class="field">
            <label asp-for="AsOfDate" class="field__label">@Html.DisplayNameFor(m => m.AsOfDate)</label>
            <input asp-for="AsOfDate" class="field__input" type="date" />
            <span asp-validation-for="AsOfDate" class="field-hint"></span>
            <p class="field-hint">Boş bırakılırsa bugün kabul edilir.</p>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Mahkumiyet süresi, cezaevine giriş tarihi ve suç tipini girip "Hesapla" butonuna
                basarak şartlı tahliye tarihini ve kalan gün sayısını görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N0", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(result.UyariMesaji))
            {
                <div class="result-note">@result.UyariMesaji</div>
            }

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/ceza">← Ceza Hukuku ve İnfaz</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var sel = document.getElementById('sucTipi');
            var info = document.getElementById('suc-oran-bilgi');
            function refresh() {
                switch (sel.value) {
                    case '1':
                        info.textContent = 'Suç tipi: Genel — oran 2/3 (%66,67).';
                        break;
                    case '2':
                        info.textContent = 'Suç tipi: Terör — oran 3/4 (%75).';
                        break;
                    case '3':
                        info.textContent = 'Suç tipi: Cinsel suç (TCK m.102/103/104/105) — oran 3/4 (%75).';
                        break;
                    case '4':
                        info.textContent = 'Suç tipi: Örgütlü suç — oran 3/4 (%75).';
                        break;
                    case '5':
                        info.textContent = 'Suç tipi: Diğer ağır suçlar (kasten öldürme vb.) — oran 3/4 (%75).';
                        break;
                }
            }
            sel.addEventListener('change', refresh);
            refresh();
        })();
    </script>
}
