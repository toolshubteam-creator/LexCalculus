@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Ceza
@model DavaZamanasimiInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as DavaZamanasimiResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Asli zamanaşımı süresinin tespitinde (TCK m.66 — 8/15/20/25/30 yıl)</li>
        <li>Kesinti (savcılık ifadesi, iddianame, vb.) sonrası yeniden başlama tarihinde</li>
        <li>Mutlak zamanaşımı sınırının (asli × 1.5, m.67/4) uygulanmasında</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        Suç ağırlığını seçtiğinizde asli ve mutlak süreler otomatik gösterilir.
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Bu hesap TCK m.66-67 zamanaşımı sürelerini uygular. Suçun
    nitelendirilmesi (basit/nitelikli, vs.), kesinti niteliği (savcılık işlemleri,
    iddianame, yakalama emri, vb.) ve m.67 son fıkra uygulaması yargılama makamı
    takdirindedir. <strong>Bu sonuç mahkeme kararı yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="DavaZamanasimi">
        <h2 class="form-section__title">Zamanaşımı Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field-row">
            <div class="field">
                <label asp-for="SucIslemeTarihi" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.SucIslemeTarihi) <span class="required">*</span>
                </label>
                <input asp-for="SucIslemeTarihi" class="field__input" type="date" />
                <span asp-validation-for="SucIslemeTarihi" class="field-hint"></span>
            </div>
            <div class="field">
                <label asp-for="SucAgirligi" class="field__label">@Html.DisplayNameFor(m => m.SucAgirligi)</label>
                <select asp-for="SucAgirligi" asp-items="Html.GetEnumSelectList<SucAgirligi>()" class="field__input"></select>
            </div>
        </div>

        <h3 class="form-section__subtitle">Kesinti Tarihleri (TCK m.67) — opsiyonel</h3>
        <p class="field-hint">Savcılık ifadesi, iddianame, yakalama emri gibi dava işlemlerinin tarihleri.</p>
        <div id="kesinti-listesi">
            @for (var i = 0; i < Model.Kesintiler.Count; i++)
            {
                <div class="field-row" data-kesinti-index="@i">
                    <div class="field">
                        <label class="field__label">Tarih</label>
                        <input asp-for="Kesintiler[i].Tarih" class="field__input" type="date" />
                    </div>
                    <div class="field">
                        <label class="field__label">İşlem Türü</label>
                        <input asp-for="Kesintiler[i].IslemTuru" class="field__input" placeholder="örn. İddianame" />
                    </div>
                </div>
            }
        </div>
        <button type="button" class="btn btn--ghost" onclick="addKesinti()">+ Kesinti Ekle</button>

        <div class="field">
            <label asp-for="AsOfDate" class="field__label">@Html.DisplayNameFor(m => m.AsOfDate)</label>
            <input asp-for="AsOfDate" class="field__input" type="date" />
            <p class="field-hint">Boş bırakılırsa bugün kabul edilir.</p>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Suç işleme tarihi ve suç ağırlığını girip "Hesapla" butonuna basarak asli ve mutlak
                zamanaşımı bitiş tarihlerini ve kalan süreyi görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @Math.Abs(result.KalanGun).ToString("N0", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/ceza">← Ceza Hukuku ve İnfaz</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function addKesinti() {
            var c = document.getElementById('kesinti-listesi');
            var i = c.children.length;
            var html =
                '<div class="field-row" data-kesinti-index="' + i + '">' +
                  '<div class="field"><label class="field__label">Tarih</label>' +
                    '<input name="Kesintiler[' + i + '].Tarih" class="field__input" type="date" /></div>' +
                  '<div class="field"><label class="field__label">İşlem Türü</label>' +
                    '<input name="Kesintiler[' + i + '].IslemTuru" class="field__input" placeholder="örn. İddianame" /></div>' +
                '</div>';
            c.insertAdjacentHTML('beforeend', html);
        }
    </script>
}
