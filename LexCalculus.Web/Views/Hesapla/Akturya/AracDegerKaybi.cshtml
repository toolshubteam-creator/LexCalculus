@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Akturya
@model AracDegerKaybiInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as AracDegerKaybiResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--warning">
    <strong>TRAMER baseline yöntemi.</strong> Eksper raporu ve mahkeme takdirine göre farklılaşabilir. Hasar oranı %30 üzeri ise araç pert sayılabilir.
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="AracDegerKaybi">
        <h2 class="form-section__title">Olay & Araç</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field">
            <label asp-for="OlayTarihi" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.OlayTarihi) <span class="required">*</span>
            </label>
            <input asp-for="OlayTarihi" class="field__input" type="date" />
            <span asp-validation-for="OlayTarihi" class="field-hint"></span>
        </div>

        <h3 class="form-section__title form-section__title--sub">Aracın Değerleri</h3>

        <div class="field-row">
            <div class="field">
                <label asp-for="KazadanOncekiDeger" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.KazadanOncekiDeger) <span class="required">*</span>
                </label>
                <input asp-for="KazadanOncekiDeger" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 800000" />
                <div class="field-hint">Kasko değeri veya piyasa değeri.</div>
                <span asp-validation-for="KazadanOncekiDeger" class="field-hint"></span>
            </div>

            <div class="field">
                <label asp-for="KazadanSonrakiDeger" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.KazadanSonrakiDeger) <span class="required">*</span>
                </label>
                <input asp-for="KazadanSonrakiDeger" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 720000" />
                <div class="field-hint">Eksper raporundaki onarılmış değer.</div>
                <span asp-validation-for="KazadanSonrakiDeger" class="field-hint"></span>
            </div>
        </div>

        <h3 class="form-section__title form-section__title--sub">Aracın Özellikleri</h3>

        <div class="field-row">
            <div class="field">
                <label asp-for="AracYas" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.AracYas) <span class="required">*</span>
                </label>
                <input asp-for="AracYas" class="field__input" type="number" step="1" min="0" max="50" placeholder="örn. 2" />
                <span asp-validation-for="AracYas" class="field-hint"></span>
            </div>

            <div class="field">
                <label asp-for="AracKm" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.AracKm) <span class="required">*</span>
                </label>
                <input asp-for="AracKm" class="field__input" type="number" step="1000" min="0" max="999999" placeholder="örn. 45000" />
                <span asp-validation-for="AracKm" class="field-hint"></span>
            </div>
        </div>

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Aracın değerlerini ve özelliklerini girip "Hesapla" butonuna basarak değer kaybı hesabını görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/akturya">← Aktüerya</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
