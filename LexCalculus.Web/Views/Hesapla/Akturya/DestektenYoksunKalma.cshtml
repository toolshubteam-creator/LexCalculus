@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Akturya
@using LexCalculus.Core.Enums
@model DesteKtenYoksunKalmaInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as DesteKtenYoksunKalmaResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Trafik kazası, iş kazası veya başka haksız fiil sonucu vefat eden kişinin desteğinden yoksun kalan yakınlarının tazminat talebinde</li>
        <li>Vefat edenin eş ve/veya çocuklarının ekonomik destek kaybının hesaplanmasında</li>
        <li>SGK ölüm aylığı dışı destek tazminatının tespitinde</li>
        <li>Sigorta şirketi davalarında bilirkişi raporu öncesi tahmin amacıyla</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        Yaralanma halinde <a href="/hesapla/akturya/maluliyet-tazminati" class="link">Maluliyet Tazminatı</a>'nı kullanın.
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Aktüeryal hesaptır.</strong> TRH 2010 yaşam tablosu, peşin değer (annuity PV) ve Yargıtay HGK pay tabloları kullanılır. Sonuç tahmindir; mahkeme bilirkişi raporuyla kesinleşir.
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="DestektenYoksunKalma">
        <h2 class="form-section__title">Olay & Ölen Kişi</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field">
            <label asp-for="OlayTarihi" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.OlayTarihi) <span class="required">*</span>
            </label>
            <input asp-for="OlayTarihi" class="field__input" type="date" />
            <span asp-validation-for="OlayTarihi" class="field-hint"></span>
        </div>

        <div class="field-row">
            <div class="field">
                <label asp-for="OlenDogumTarihi" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.OlenDogumTarihi) <span class="required">*</span>
                </label>
                <input asp-for="OlenDogumTarihi" class="field__input" type="date" />
                <span asp-validation-for="OlenDogumTarihi" class="field-hint"></span>
            </div>

            <div class="field">
                <label asp-for="OlenCinsiyet" class="field__label">
                    @Html.DisplayNameFor(m => m.OlenCinsiyet)
                </label>
                <select asp-for="OlenCinsiyet" asp-items="Html.GetEnumSelectList<Cinsiyet>()" class="field__input"></select>
            </div>
        </div>

        <div class="field">
            <label asp-for="AylikGelir" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.AylikGelir) <span class="required">*</span>
            </label>
            <input asp-for="AylikGelir" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 30000" />
            <div class="field-hint">Ölen kişinin olay tarihindeki aylık net geliri.</div>
            <span asp-validation-for="AylikGelir" class="field-hint"></span>
        </div>

        <h3 class="form-section__title form-section__title--sub">Eş Bilgileri</h3>

        <div class="field">
            <label class="field__label field__label--checkbox">
                <input asp-for="EsVarMi" type="checkbox" />
                <span>@Html.DisplayNameFor(m => m.EsVarMi)</span>
            </label>
        </div>

        <div class="field-row">
            <div class="field">
                <label asp-for="EsDogumTarihi" class="field__label">
                    @Html.DisplayNameFor(m => m.EsDogumTarihi)
                </label>
                <input asp-for="EsDogumTarihi" class="field__input" type="date" />
                <span asp-validation-for="EsDogumTarihi" class="field-hint"></span>
            </div>

            <div class="field">
                <label asp-for="EsCinsiyet" class="field__label">
                    @Html.DisplayNameFor(m => m.EsCinsiyet)
                </label>
                <select asp-for="EsCinsiyet" asp-items="Html.GetEnumSelectList<Cinsiyet>()" class="field__input"></select>
            </div>
        </div>

        <h3 class="form-section__title form-section__title--sub">Çocuklar</h3>

        <div class="cocuk-list" id="cocukList" data-cocuk-list>
            @if (Model.Cocuklar?.Count > 0)
            {
                for (int i = 0; i < Model.Cocuklar.Count; i++)
                {
                    ViewData["Index"] = i;
                    @await Html.PartialAsync("~/Views/Hesapla/Akturya/_CocukRow.cshtml", Model.Cocuklar[i])
                }
            }
        </div>

        <button type="button" class="btn btn--ghost btn--small" id="addCocukBtn" data-add-cocuk>
            + Çocuk Ekle
        </button>

        <h3 class="form-section__title form-section__title--sub">Aktüeryal Varsayımlar</h3>

        <div class="field-row">
            <div class="field">
                <label asp-for="YillikIskontoOrani" class="field__label">
                    @Html.DisplayNameFor(m => m.YillikIskontoOrani)
                </label>
                <input asp-for="YillikIskontoOrani" class="field__input" type="number" step="0.1" min="0" max="20" />
                <div class="field-hint">Yargıtay tipik %1.8-%4 arası. Default %3.</div>
            </div>

            <div class="field">
                <label asp-for="PasifDonemGelirOrani" class="field__label">
                    @Html.DisplayNameFor(m => m.PasifDonemGelirOrani)
                </label>
                <input asp-for="PasifDonemGelirOrani" class="field__input" type="number" step="5" min="20" max="100" />
                <div class="field-hint">Emeklilik döneminde gelirin yüzdesi. Default %50.</div>
            </div>
        </div>

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Olay ve aile bilgilerini doldurup "Hesapla" butonuna basarak destekten yoksun kalma tazminatı hesabını görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @if (result.CocukDetaylar.Any())
            {
                <div class="result-detail">
                    <h4 class="result-detail__title">Çocuk Bazında Dağılım</h4>
                    <div class="result-detail__table">
                        @foreach (var c in result.CocukDetaylar)
                        {
                            <div class="result-row">
                                <span class="result-row__key">@c.Aciklama (@c.DestekSuresi yıl)</span>
                                <span class="result-row__val">@c.Tutar.ToString("N2", tr) TL</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/akturya">← Aktüerya</a>
</div>

<script>
(function () {
    const list = document.querySelector('[data-cocuk-list]');
    const addBtn = document.querySelector('[data-add-cocuk]');

    function rowTemplate(idx) {
        const prefix = `Cocuklar[${idx}]`;
        return `
        <div class="cocuk-row" data-cocuk-row>
            <div class="field-row cocuk-row__fields">
                <div class="field">
                    <label class="field__label field__label--required">Doğum Tarihi <span class="required">*</span></label>
                    <input name="${prefix}.DogumTarihi" class="field__input" type="date" required />
                </div>
                <div class="field">
                    <label class="field__label">Cinsiyet</label>
                    <select name="${prefix}.Cinsiyet" class="field__input">
                        <option value="Erkek">Erkek</option>
                        <option value="Kadin">Kadın</option>
                    </select>
                </div>
                <div class="field cocuk-row__ogrenci">
                    <label class="field__label field__label--checkbox">
                        <input name="${prefix}.Ogrenci" type="checkbox" value="true" />
                        <span>Eğitimde</span>
                    </label>
                    <input type="hidden" name="${prefix}.Ogrenci" value="false" />
                </div>
            </div>
            <button type="button" class="btn btn--ghost btn--small cocuk-row__remove" data-remove-row>Sil</button>
        </div>`;
    }

    function reindexRows() {
        const rows = list.querySelectorAll('[data-cocuk-row]');
        rows.forEach((row, idx) => {
            row.querySelectorAll('input[name^="Cocuklar["], select[name^="Cocuklar["]').forEach(el => {
                el.name = el.name.replace(/Cocuklar\[\d+\]/, `Cocuklar[${idx}]`);
            });
        });
    }

    addBtn.addEventListener('click', function () {
        const idx = list.querySelectorAll('[data-cocuk-row]').length;
        const div = document.createElement('div');
        div.innerHTML = rowTemplate(idx).trim();
        list.appendChild(div.firstChild);
    });

    list.addEventListener('click', function (e) {
        if (e.target.matches('[data-remove-row]')) {
            e.target.closest('[data-cocuk-row]').remove();
            reindexRows();
        }
    });
})();
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
