@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Akturya
@model GeciciIsGoremezlikInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as GeciciIsGoremezlikResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Trafik veya iş kazası sonucu geçici süre çalışamayan kişinin kazanç kaybı talebinde</li>
        <li>SGK iş göremezlik ödeneği ile gerçek kazanç arasındaki farkın tespitinde</li>
        <li>Hastane raporu süresince yaşanan gelir kaybının sorumlu taraftan tahsilinde</li>
        <li>Kayıt dışı çalışan işçinin SGK ödeneği almadan tüm kaybının hesabında</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        Kalıcı kayıp için <a href="/hesapla/akturya/maluliyet-tazminati" class="link">Maluliyet Tazminatı</a>'nı kullanın. Zamanaşımı 2 yıl (TBK m.72).
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>SGK ödeneği mahsup edilir.</strong> 5510 s.K. m.18 uyarınca SGK günlük kazancın 2/3'ünü öder; kalan 1/3 sorumlu taraftan TBK m.54 uyarınca istenebilir. SGK kayıt dışı çalışmaya ödeme yapmaz; o durumda mahsup kapatılmalıdır.
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="GeciciIsGoremezlik">
        <h2 class="form-section__title">Olay & Süre</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field-row">
            <div class="field">
                <label asp-for="OlayTarihi" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.OlayTarihi) <span class="required">*</span>
                </label>
                <input asp-for="OlayTarihi" class="field__input" type="date" />
                <span asp-validation-for="OlayTarihi" class="field-hint"></span>
            </div>

            <div class="field">
                <label asp-for="SureGun" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.SureGun) <span class="required">*</span>
                </label>
                <input asp-for="SureGun" class="field__input" type="number" step="1" min="1" max="1825" placeholder="örn. 90" />
                <span asp-validation-for="SureGun" class="field-hint"></span>
            </div>
        </div>

        <div class="field">
            <label asp-for="AylikBrutUcret" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.AylikBrutUcret) <span class="required">*</span>
            </label>
            <input asp-for="AylikBrutUcret" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 30000" />
            <span asp-validation-for="AylikBrutUcret" class="field-hint"></span>
        </div>

        <h3 class="form-section__title form-section__title--sub">SGK Ödeneği</h3>

        <div class="field">
            <label class="field__label field__label--checkbox">
                <input asp-for="SgkMahsup" type="checkbox" />
                <span>@Html.DisplayNameFor(m => m.SgkMahsup)</span>
            </label>
            <div class="field-hint">SGK kayıt dışı çalışmaya ödeme yapmaz; bu durumda kapatın.</div>
        </div>

        <div class="field">
            <label asp-for="SgkOrani" class="field__label">
                @Html.DisplayNameFor(m => m.SgkOrani)
            </label>
            <input asp-for="SgkOrani" class="field__input" type="number" step="0.01" min="0" max="100" />
            <div class="field-hint">5510 s.K. m.18 uyarınca 2/3 (yaklaşık %66.67).</div>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Olay süresi ve aylık brüt ücreti girip "Hesapla" butonuna basarak geçici iş göremezlik tazminatını görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/akturya">← Aktüerya</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
