@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.Akturya
@using LexCalculus.Core.Enums
@model BakiciGideriInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as BakiciGideriResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Yaralının kalıcı bakıma muhtaç hale gelmesi durumunda gelecekteki bakım maliyetinin talebinde</li>
        <li>Refakatçi ihtiyacı raporlanmış durumlarda günlük saat oranına göre hesap çıkarılmasında</li>
        <li>Trafik veya iş kazası sonucu evde bakım/profesyonel bakıcı gerektiren senaryolarda</li>
        <li>Maluliyet tazminatına ek olarak ayrı bir kalem talep edildiğinde</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        Bakım ihtiyaç oranı Adli Tıp / Sağlık Kurulu raporu ile tespit edilir.
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Aktüeryal hesaptır.</strong> Bakım ihtiyaç oranı Adli Tıp / Sağlık Kurulu raporu ile tespit edilir.
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="BakiciGideri">
        <h2 class="form-section__title">Yaralanan Kişi</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field">
            <label asp-for="OlayTarihi" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.OlayTarihi) <span class="required">*</span>
            </label>
            <input asp-for="OlayTarihi" class="field__input" type="date" />
            <span asp-validation-for="OlayTarihi" class="field-hint"></span>
        </div>

        <div class="field-row">
            <div class="field">
                <label asp-for="YaralananDogumTarihi" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.YaralananDogumTarihi) <span class="required">*</span>
                </label>
                <input asp-for="YaralananDogumTarihi" class="field__input" type="date" />
                <span asp-validation-for="YaralananDogumTarihi" class="field-hint"></span>
            </div>

            <div class="field">
                <label asp-for="Cinsiyet" class="field__label">
                    @Html.DisplayNameFor(m => m.Cinsiyet)
                </label>
                <select asp-for="Cinsiyet" asp-items="Html.GetEnumSelectList<Cinsiyet>()" class="field__input"></select>
            </div>
        </div>

        <h3 class="form-section__title form-section__title--sub">Bakıcı Bilgileri</h3>

        <div class="field-row">
            <div class="field">
                <label asp-for="AylikBakiciMaliyeti" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.AylikBakiciMaliyeti) <span class="required">*</span>
                </label>
                <input asp-for="AylikBakiciMaliyeti" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 26000" />
                <div class="field-hint">Genelde asgari ücret veya katı (24 saat bakım için 1.5-2x asgari).</div>
                <span asp-validation-for="AylikBakiciMaliyeti" class="field-hint"></span>
            </div>

            <div class="field">
                <label asp-for="BakimIhtiyacOrani" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.BakimIhtiyacOrani) <span class="required">*</span>
                </label>
                <input asp-for="BakimIhtiyacOrani" class="field__input" type="number" step="1" min="1" max="100" placeholder="örn. 100" />
                <div class="field-hint">24h tam = %100, 6h refakat ≈ %25.</div>
                <span asp-validation-for="BakimIhtiyacOrani" class="field-hint"></span>
            </div>
        </div>

        <div class="field">
            <label asp-for="YillikIskontoOrani" class="field__label">
                @Html.DisplayNameFor(m => m.YillikIskontoOrani)
            </label>
            <input asp-for="YillikIskontoOrani" class="field__input" type="number" step="0.1" min="0" max="20" />
            <div class="field-hint">Yargıtay tipik %1.8-%4. Default %3.</div>
        </div>

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Yaralanan ve bakıcı bilgilerini girip "Hesapla" butonuna basarak bakıcı gideri tazminatı hesabını görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/akturya">← Aktüerya</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
