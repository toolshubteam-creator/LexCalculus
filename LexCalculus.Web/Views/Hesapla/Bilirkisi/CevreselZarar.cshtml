@using LexCalculus.Core.Calculators.Bilirkisi
@using LexCalculus.Core.Calculators.Common
@model CevreselZararInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as CevreselZararResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>2872 s.K. m.28 çevre zararı tazminat kalem toplamı</li>
        <li>Doğrudan zarar + restorasyon maliyeti + ekosistem kaybı kombinasyonu</li>
        <li>Opsiyonel bilirkişi/uzman maliyeti eklemesi (toplam zarar üzerinden %0-15)</li>
    </ul>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Bu hesap 2872 s.K. m.28 çevre zararı kalem toplamı formülünü
    uygular. Restorasyon maliyeti uzman çevre mühendisi raporuna, ekosistem kaybı uzun
    vadeli ekolojik analize dayanır. Manevi tazminat ve 2872 s.K. m.20 idari para cezası
    bu hesabın dışındadır.
    <strong>Bu sonuç bilirkişi raporu yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="CevreselZarar">
        <h2 class="form-section__title">Zarar Kalemleri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field">
            <label asp-for="DogrudanZarar" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.DogrudanZarar) <span class="required">*</span>
            </label>
            <input asp-for="DogrudanZarar" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 100000" />
            <span asp-validation-for="DogrudanZarar" class="field-hint"></span>
        </div>

        <div class="field">
            <label asp-for="RestorasyonMaliyeti" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.RestorasyonMaliyeti) <span class="required">*</span>
            </label>
            <input asp-for="RestorasyonMaliyeti" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 250000" />
            <span asp-validation-for="RestorasyonMaliyeti" class="field-hint"></span>
        </div>

        <div class="field">
            <label asp-for="EkosistemKaybi" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.EkosistemKaybi) <span class="required">*</span>
            </label>
            <input asp-for="EkosistemKaybi" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 75000" />
            <span asp-validation-for="EkosistemKaybi" class="field-hint"></span>
        </div>

        <div class="field">
            <label asp-for="BilirkisiMaliyetOraniYuzde" class="field__label">@Html.DisplayNameFor(m => m.BilirkisiMaliyetOraniYuzde)</label>
            <input asp-for="BilirkisiMaliyetOraniYuzde" class="field__input" type="number" step="0.01" min="0" max="15" placeholder="örn. 10" />
            <span asp-validation-for="BilirkisiMaliyetOraniYuzde" class="field-hint"></span>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Zarar kalemlerini girip "Hesapla" butonuna basarak toplam tazminatı
                görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/bilirkisi">← Bilirkişilik Özel Araçları</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
