@using LexCalculus.Core.Calculators.Bilirkisi
@using LexCalculus.Core.Calculators.Common
@model IskontoluNakitAkisiInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as IskontoluNakitAkisiResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Yıllık gelirin lump-sum (tek seferlik) bugünkü değerinin (PV) tespitinde</li>
        <li>Tazminat alternatif değer projeksiyonlarında (anüite-certain)</li>
        <li>Bilirkişi rapor şablonlarında iskonto oranı seçimiyle</li>
    </ul>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Yargıtay HGK içtihatlarına uygun anüite formülü uygulanır.
    İskonto oranı seçimi bilirkişi takdirine bağlıdır (genelde %5-10 bandı). Enflasyon,
    ücret artışı, vergisel etkiler gibi reel değişkenler ayrıca değerlendirilir.
    <strong>Bu sonuç bilirkişi raporu yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="IskontoluNakitAkisi">
        <h2 class="form-section__title">Anüite Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field">
            <label asp-for="YillikNetGelir" class="field__label field__label--required">
                @Html.DisplayNameFor(m => m.YillikNetGelir) <span class="required">*</span>
            </label>
            <input asp-for="YillikNetGelir" class="field__input" type="number" step="0.01" min="0.01" placeholder="örn. 240000" />
            <span asp-validation-for="YillikNetGelir" class="field-hint"></span>
        </div>

        <div class="field-row">
            <div class="field">
                <label asp-for="IskontoOraniYuzde" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.IskontoOraniYuzde) <span class="required">*</span>
                </label>
                <input asp-for="IskontoOraniYuzde" class="field__input" type="number" step="0.01" min="0" max="100" placeholder="örn. 7" />
                <span asp-validation-for="IskontoOraniYuzde" class="field-hint"></span>
            </div>
            <div class="field">
                <label asp-for="YilSayisi" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.YilSayisi) <span class="required">*</span>
                </label>
                <input asp-for="YilSayisi" class="field__input" type="number" step="1" min="1" max="200" placeholder="örn. 20" />
                <span asp-validation-for="YilSayisi" class="field-hint"></span>
            </div>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Yıllık gelir, iskonto oranı ve yıl sayısını girip "Hesapla" butonuna basarak
                bugünkü değeri (PV) görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/bilirkisi">← Bilirkişilik Özel Araçları</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
