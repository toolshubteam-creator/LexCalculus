@using LexCalculus.Core.Calculators.Bilirkisi
@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Enums
@model YasamTablosuSorguInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as YasamTablosuSorguResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Bilirkişi raporlarında kalan yaşam umudunun (eX) tespitinde</li>
        <li>Destekten yoksun kalma, maluliyet, anüite hesapları için temel girdi</li>
        <li>Tek yaş veya yaş aralığı sorgusu (cinsiyet bazlı)</li>
    </ul>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> TRH 2010 (Türkiye Hayat Tablosu) verisi kullanılır. Tablo
    değerleri TÜİK güncellemelerine tabidir. Destekten yoksun kalma, maluliyet, anüite gibi
    tazminat hesaplarında temel girdidir ancak hesabın tamamı değildir.
    <strong>Bu sorgu sonucu kesin tazminat hesabı yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="YasamTablosuSorgu">
        <h2 class="form-section__title">Sorgu Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field-row">
            <div class="field">
                <label asp-for="SorguTipi" class="field__label">@Html.DisplayNameFor(m => m.SorguTipi)</label>
                <select asp-for="SorguTipi" asp-items="Html.GetEnumSelectList<YasamSorguTipi>()" class="field__input" id="sorguTipi"></select>
            </div>
            <div class="field">
                <label asp-for="Cinsiyet" class="field__label">@Html.DisplayNameFor(m => m.Cinsiyet)</label>
                <select asp-for="Cinsiyet" asp-items="Html.GetEnumSelectList<Cinsiyet>()" class="field__input"></select>
            </div>
        </div>

        <div data-group="tek">
            <div class="field">
                <label asp-for="Yas" class="field__label">@Html.DisplayNameFor(m => m.Yas)</label>
                <input asp-for="Yas" class="field__input" type="number" step="1" min="0" max="105" placeholder="örn. 40" />
                <span asp-validation-for="Yas" class="field-hint"></span>
            </div>
        </div>

        <div data-group="aralik">
            <div class="field-row">
                <div class="field">
                    <label asp-for="BaslangicYas" class="field__label">@Html.DisplayNameFor(m => m.BaslangicYas)</label>
                    <input asp-for="BaslangicYas" class="field__input" type="number" step="1" min="0" max="105" placeholder="örn. 30" />
                    <span asp-validation-for="BaslangicYas" class="field-hint"></span>
                </div>
                <div class="field">
                    <label asp-for="BitisYas" class="field__label">@Html.DisplayNameFor(m => m.BitisYas)</label>
                    <input asp-for="BitisYas" class="field__input" type="number" step="1" min="0" max="105" placeholder="örn. 50" />
                    <span asp-validation-for="BitisYas" class="field-hint"></span>
                </div>
            </div>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Sorgula</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Yaş ve cinsiyeti girip "Sorgula" butonuna basarak TRH 2010 tablosundan kalan
                yaşam umudunu (eX) görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("0.##", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/bilirkisi">← Bilirkişilik Özel Araçları</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var sel = document.getElementById('sorguTipi');
            function show(group, vis) {
                var el = document.querySelector('[data-group="' + group + '"]');
                if (el) el.style.display = vis ? '' : 'none';
            }
            function refresh() {
                var tek = sel.value === '1';
                show('tek', tek);
                show('aralik', !tek);
            }
            sel.addEventListener('change', refresh);
            refresh();
        })();
    </script>
}
