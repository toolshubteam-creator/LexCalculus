@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.AileMiras
@model NafakaInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as NafakaResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>İştirak nafakası (çocuk için, TMK m.182) — yaş, eğitim ve ikamet katsayılarıyla</li>
        <li>Yoksulluk nafakası (eş için, TMK m.175) — gelir farkı ve evlilik süresiyle</li>
        <li>Tedbir nafakası (dava süresince, TMK m.169) — geçici nitelikte</li>
        <li>Mevcut nafakanın TÜFE 12 aylık ortalamayla artışı</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        Nafaka türünü ve hesap türünü seçtikçe ilgili alanlar görünür.
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Bu hesap referans niteliğindedir. Mahkeme TMK m.4 takdir yetkisini kullanır.
    Somut davada çocuğun özel ihtiyaçları (sağlık, özel eğitim), yükümlünün diğer bakmakla yükümlü
    olduğu kişiler, gelir belgeleme durumu gibi faktörler değerlendirilir.
    <strong>Bu sonuç mahkeme kararı yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="Nafaka">
        <h2 class="form-section__title">Nafaka Bilgileri</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field-row">
            <div class="field">
                <label asp-for="NafakaTuru" class="field__label">@Html.DisplayNameFor(m => m.NafakaTuru)</label>
                <select asp-for="NafakaTuru" asp-items="Html.GetEnumSelectList<NafakaTuru>()" class="field__input" id="nafakaTuru"></select>
            </div>
            <div class="field">
                <label asp-for="HesapTuru" class="field__label">@Html.DisplayNameFor(m => m.HesapTuru)</label>
                <select asp-for="HesapTuru" asp-items="Html.GetEnumSelectList<NafakaHesapTuru>()" class="field__input" id="hesapTuru"></select>
            </div>
        </div>

        <!-- İştirak (yeni belirleme) -->
        <div data-group="istirak">
            <div class="field-row">
                <div class="field">
                    <label asp-for="YukumluNetGelir" class="field__label">@Html.DisplayNameFor(m => m.YukumluNetGelir)</label>
                    <input asp-for="YukumluNetGelir" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 60000" />
                    <span asp-validation-for="YukumluNetGelir" class="field-hint"></span>
                </div>
                <div class="field">
                    <label asp-for="Sehir" class="field__label">@Html.DisplayNameFor(m => m.Sehir)</label>
                    <select asp-for="Sehir" asp-items="Html.GetEnumSelectList<SehirTuru>()" class="field__input"></select>
                </div>
            </div>

            <h3 class="form-section__subtitle">Çocuklar</h3>
            <p class="field-hint">Her çocuk için yaş ve eğitim seviyesi girilir.</p>
            <div id="cocuk-listesi">
                @for (var i = 0; i < Model.Cocuklar.Count; i++)
                {
                    <div class="field-row" data-cocuk-index="@i">
                        <div class="field">
                            <label class="field__label">Yaş</label>
                            <input asp-for="Cocuklar[i].Yas" class="field__input" type="number" step="1" min="0" max="17" placeholder="örn. 8" />
                        </div>
                        <div class="field">
                            <label class="field__label">Eğitim Seviyesi</label>
                            <select asp-for="Cocuklar[i].EgitimSeviyesi" asp-items="Html.GetEnumSelectList<EgitimSeviyesi>()" class="field__input"></select>
                        </div>
                    </div>
                }
            </div>
            <button type="button" class="btn btn--ghost" onclick="addCocuk()">+ Yeni Çocuk Ekle</button>
        </div>

        <!-- Yoksulluk / Tedbir (yeni belirleme) -->
        <div data-group="yoksulluk">
            <div class="field-row">
                <div class="field">
                    <label asp-for="YuksekGelirEs" class="field__label">@Html.DisplayNameFor(m => m.YuksekGelirEs)</label>
                    <input asp-for="YuksekGelirEs" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 50000" />
                    <span asp-validation-for="YuksekGelirEs" class="field-hint"></span>
                </div>
                <div class="field">
                    <label asp-for="DusukGelirEs" class="field__label">@Html.DisplayNameFor(m => m.DusukGelirEs)</label>
                    <input asp-for="DusukGelirEs" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 20000" />
                    <span asp-validation-for="DusukGelirEs" class="field-hint"></span>
                </div>
            </div>
            <div class="field">
                <label asp-for="EvlilikSuresiAy" class="field__label">@Html.DisplayNameFor(m => m.EvlilikSuresiAy)</label>
                <input asp-for="EvlilikSuresiAy" class="field__input" type="number" step="1" min="0" placeholder="örn. 96" />
                <span asp-validation-for="EvlilikSuresiAy" class="field-hint"></span>
            </div>
        </div>

        <!-- Artış -->
        <div data-group="artis">
            <div class="field-row">
                <div class="field">
                    <label asp-for="MevcutAylikNafaka" class="field__label">@Html.DisplayNameFor(m => m.MevcutAylikNafaka)</label>
                    <input asp-for="MevcutAylikNafaka" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 5000" />
                    <span asp-validation-for="MevcutAylikNafaka" class="field-hint"></span>
                </div>
                <div class="field">
                    <label asp-for="HesapTarihi" class="field__label">@Html.DisplayNameFor(m => m.HesapTarihi)</label>
                    <input asp-for="HesapTarihi" class="field__input" type="date" />
                    <span asp-validation-for="HesapTarihi" class="field-hint"></span>
                </div>
            </div>
            <div class="field">
                <label asp-for="TufeOverride" class="field__label">@Html.DisplayNameFor(m => m.TufeOverride)</label>
                <input asp-for="TufeOverride" class="field__input" type="number" step="0.01" min="0" placeholder="sistemde olmayan aylar için" />
                <span asp-validation-for="TufeOverride" class="field-hint"></span>
            </div>
        </div>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Nafaka türünü ve gerekli bilgileri girip "Hesapla" butonuna basarak önerilen aylık
                nafaka tutarını görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/aile-miras">← Aile ve Miras Hukuku</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function addCocuk() {
            var container = document.getElementById('cocuk-listesi');
            var index = container.children.length;
            var html =
                '<div class="field-row" data-cocuk-index="' + index + '">' +
                  '<div class="field">' +
                    '<label class="field__label">Yaş</label>' +
                    '<input name="Cocuklar[' + index + '].Yas" class="field__input" type="number" step="1" min="0" max="17" placeholder="örn. 8" />' +
                  '</div>' +
                  '<div class="field">' +
                    '<label class="field__label">Eğitim Seviyesi</label>' +
                    '<select name="Cocuklar[' + index + '].EgitimSeviyesi" class="field__input">' +
                      '<option value="1">Okul Öncesi / Anaokulu</option>' +
                      '<option value="2">İlkokul</option>' +
                      '<option value="3">Ortaokul</option>' +
                      '<option value="4">Lise</option>' +
                      '<option value="5">Üniversite</option>' +
                    '</select>' +
                  '</div>' +
                '</div>';
            container.insertAdjacentHTML('beforeend', html);
        }

        (function () {
            var nafakaTuru = document.getElementById('nafakaTuru');
            var hesapTuru = document.getElementById('hesapTuru');

            function show(group, visible) {
                var el = document.querySelector('[data-group="' + group + '"]');
                if (el) el.style.display = visible ? '' : 'none';
            }

            function refresh() {
                var artis = hesapTuru.value === '2'; // Artis
                var istirak = nafakaTuru.value === '1'; // Istirak
                show('artis', artis);
                show('istirak', !artis && istirak);
                show('yoksulluk', !artis && !istirak);
            }

            nafakaTuru.addEventListener('change', refresh);
            hesapTuru.addEventListener('change', refresh);
            refresh();
        })();
    </script>
}
