@using LexCalculus.Core.Calculators.Common
@using LexCalculus.Core.Calculators.AileMiras
@model TenkisInput
@{
    var meta = (CalculatorMetadata)ViewData["Meta"]!;
    var result = ViewData["Result"] as TenkisResult;
    var tr = new System.Globalization.CultureInfo("tr-TR");
}

<div class="calc-header">
    <h1 class="calc-header__title">@meta.Title</h1>
    <div class="calc-meta">
        <div>№ <strong>@meta.DisplayNumber</strong></div>
        <div>@meta.LegalReference</div>
        <div>@meta.Category.ToShortName().ToUpper()</div>
    </div>
</div>

<section class="hero hero--inline">
    <p class="hero__lead hero__lead--narrow">@meta.ShortDescription</p>
</section>

<div class="info-box info-box--info">
    <strong>Bu hesap ne zaman kullanılır?</strong>
    <ul style="margin: var(--sp-2) 0 0 var(--sp-4); padding: 0;">
        <li>Vasiyet veya bağışın saklı payı ihlal edip etmediğinin tespitinde</li>
        <li>Tasarruf nisabı (serbestçe tasarruf edilebilen kısım) hesabında</li>
        <li>Tenkis sırasının belirlenmesinde (önce vasiyet, sonra son bağıştan geriye)</li>
    </ul>
    <div style="font-size: var(--fs-xs); margin-top: var(--sp-3); opacity: 0.8;">
        Tenkise esas matrah = ölüm anı malvarlığı + sağlar arası bağışlar (TMK m.565).
    </div>
</div>

<div class="info-box info-box--warning">
    <strong>Uyarı:</strong> Tenkis hesabı TMK m.506 saklı pay ve m.560-571 tenkis sırasına dayanır.
    Sağlar arası bağışlar TMK m.565 uyarınca geri eklenir. Mirastan ıskat, mirastan yoksunluk,
    bağışın geri istenmesi (TMK m.567) gibi durumlar ayrıca değerlendirilir.
    <strong>Bu sonuç mahkeme kararı yerine geçmez.</strong>
</div>

<div class="calc-layout">
    <form method="post" class="form-section" asp-controller="Hesapla" asp-action="Tenkis">
        <h2 class="form-section__title">Tereke ve Tasarruflar</h2>

        <div asp-validation-summary="ModelOnly" class="info-box info-box--danger" role="alert"></div>

        <div class="field-row">
            <div class="field">
                <label asp-for="ToplamMalvarligi" class="field__label field__label--required">
                    @Html.DisplayNameFor(m => m.ToplamMalvarligi) <span class="required">*</span>
                </label>
                <input asp-for="ToplamMalvarligi" class="field__input" type="number" step="0.01" min="0" placeholder="örn. 1000000" />
                <span asp-validation-for="ToplamMalvarligi" class="field-hint"></span>
            </div>
            <div class="field">
                <label asp-for="VasiyetnameTutari" class="field__label">@Html.DisplayNameFor(m => m.VasiyetnameTutari)</label>
                <input asp-for="VasiyetnameTutari" class="field__input" type="number" step="0.01" min="0" placeholder="opsiyonel" />
                <span asp-validation-for="VasiyetnameTutari" class="field-hint"></span>
            </div>
        </div>

        <h3 class="form-section__subtitle">Mirasçı Yapısı</h3>
        <div class="field">
            <label class="field__label"><input asp-for="Yapi.SagKalanEsVar" type="checkbox" /> @Html.DisplayNameFor(m => m.Yapi.SagKalanEsVar)</label>
        </div>
        <div class="field">
            <label asp-for="Yapi.SagCocukSayisi" class="field__label">@Html.DisplayNameFor(m => m.Yapi.SagCocukSayisi)</label>
            <input asp-for="Yapi.SagCocukSayisi" class="field__input" type="number" step="1" min="0" />
        </div>
        <p class="field-hint">Ölmüş çocuk (halefiyet — torunlar):</p>
        <div id="olmus-cocuk-listesi">
            @for (var i = 0; i < Model.Yapi.OlmusCocuklar.Count; i++)
            {
                <div class="field-row" data-oc-index="@i">
                    <div class="field">
                        <label class="field__label">Tanım</label>
                        <input asp-for="Yapi.OlmusCocuklar[i].Tanim" class="field__input" />
                    </div>
                    <div class="field">
                        <label class="field__label">Torun Sayısı</label>
                        <input asp-for="Yapi.OlmusCocuklar[i].TorunSayisi" class="field__input" type="number" step="1" min="0" />
                    </div>
                </div>
            }
        </div>
        <button type="button" class="btn btn--ghost" onclick="addOlmusCocuk()">+ Ölmüş Çocuk Ekle</button>

        <div class="field-row">
            <div class="field">
                <label class="field__label"><input asp-for="Yapi.AnaSag" type="checkbox" /> @Html.DisplayNameFor(m => m.Yapi.AnaSag)</label>
            </div>
            <div class="field">
                <label class="field__label"><input asp-for="Yapi.BabaSag" type="checkbox" /> @Html.DisplayNameFor(m => m.Yapi.BabaSag)</label>
            </div>
        </div>
        <div class="field-row">
            <div class="field">
                <label asp-for="Yapi.KardesSayisi" class="field__label">@Html.DisplayNameFor(m => m.Yapi.KardesSayisi)</label>
                <input asp-for="Yapi.KardesSayisi" class="field__input" type="number" step="1" min="0" />
            </div>
            <div class="field">
                <label asp-for="Yapi.DedeNineSayisi" class="field__label">@Html.DisplayNameFor(m => m.Yapi.DedeNineSayisi)</label>
                <input asp-for="Yapi.DedeNineSayisi" class="field__input" type="number" step="1" min="0" max="4" />
            </div>
        </div>

        <h3 class="form-section__subtitle">Sağlar Arası Bağışlar</h3>
        <p class="field-hint">Tenkis sırası için tarih zorunludur (son bağıştan geriye doğru tenkis edilir).</p>
        <div id="bagis-listesi">
            @for (var i = 0; i < Model.Bagislar.Count; i++)
            {
                <div class="field-row" data-bagis-index="@i">
                    <div class="field">
                        <label class="field__label">Tarih</label>
                        <input asp-for="Bagislar[i].Tarih" class="field__input" type="date" />
                    </div>
                    <div class="field">
                        <label class="field__label">Tutar (TL)</label>
                        <input asp-for="Bagislar[i].Tutar" class="field__input" type="number" step="0.01" min="0" />
                    </div>
                    <div class="field">
                        <label class="field__label">Alıcı</label>
                        <input asp-for="Bagislar[i].AliciTanim" class="field__input" placeholder="opsiyonel" />
                    </div>
                </div>
            }
        </div>
        <button type="button" class="btn btn--ghost" onclick="addBagis()">+ Bağış Ekle</button>

        @await Html.PartialAsync("_PaylasimToggle", (bool?)null)

        <button type="submit" class="btn btn--primary btn--block">Hesapla</button>
    </form>

    <div class="result-panel">
        <h3 class="result-panel__title">Sonuç</h3>

        @if (result is null)
        {
            <div class="result-panel__empty">
                Tereke, mirasçı yapısı ve tasarrufları girip "Hesapla" butonuna basarak saklı pay ihlali ve tenkis tutarlarını görüntüleyebilirsiniz.
            </div>
        }
        else
        {
            <div class="result-total">
                <div class="result-total__label">@result.TotalLabel</div>
                <div class="result-total__amount">
                    @result.TotalAmount?.ToString("N2", tr)<span class="result-total__currency">@result.Unit</span>
                </div>
            </div>

            <div class="result-rows">
                @foreach (var row in result.Rows)
                {
                    <div class="result-row @(row.IsHighlighted ? "result-row--highlighted" : "")">
                        <span class="result-row__key">@row.Key</span>
                        <span class="result-row__val">@row.Value</span>
                    </div>
                }
            </div>

            @foreach (var warning in result.Warnings)
            {
                <div class="result-note">@warning</div>
            }

            @if (!string.IsNullOrWhiteSpace(result.Note))
            {
                <div class="result-note">@Html.Raw(result.Note)</div>
            }
        }
    </div>
</div>

<div class="catalog-back-link">
    <a class="btn btn--ghost" href="/hesapla/aile-miras">← Aile ve Miras Hukuku</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function addOlmusCocuk() {
            var c = document.getElementById('olmus-cocuk-listesi');
            var i = c.children.length;
            c.insertAdjacentHTML('beforeend',
                '<div class="field-row" data-oc-index="' + i + '">' +
                  '<div class="field"><label class="field__label">Tanım</label>' +
                    '<input name="Yapi.OlmusCocuklar[' + i + '].Tanim" class="field__input" /></div>' +
                  '<div class="field"><label class="field__label">Torun Sayısı</label>' +
                    '<input name="Yapi.OlmusCocuklar[' + i + '].TorunSayisi" class="field__input" type="number" step="1" min="0" /></div>' +
                '</div>');
        }
        function addBagis() {
            var c = document.getElementById('bagis-listesi');
            var i = c.children.length;
            c.insertAdjacentHTML('beforeend',
                '<div class="field-row" data-bagis-index="' + i + '">' +
                  '<div class="field"><label class="field__label">Tarih</label>' +
                    '<input name="Bagislar[' + i + '].Tarih" class="field__input" type="date" /></div>' +
                  '<div class="field"><label class="field__label">Tutar (TL)</label>' +
                    '<input name="Bagislar[' + i + '].Tutar" class="field__input" type="number" step="0.01" min="0" /></div>' +
                  '<div class="field"><label class="field__label">Alıcı</label>' +
                    '<input name="Bagislar[' + i + '].AliciTanim" class="field__input" placeholder="opsiyonel" /></div>' +
                '</div>');
        }
    </script>
}
