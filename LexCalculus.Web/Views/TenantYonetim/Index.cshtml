@model LexCalculus.Web.Models.TenantYonetim.TenantYonetimVm
@using LexCalculus.Core.Entities.Identity
@{
    string StatusLabel(TenantInvitationStatus s) => s switch
    {
        TenantInvitationStatus.Pending => "Beklemede",
        TenantInvitationStatus.Accepted => "Kabul edildi",
        TenantInvitationStatus.Cancelled => "İptal",
        TenantInvitationStatus.Expired => "Süresi doldu",
        _ => s.ToString()
    };

    string StatusBadge(TenantInvitationStatus s) => s switch
    {
        TenantInvitationStatus.Pending => "tenant-yonetim__badge--pending",
        TenantInvitationStatus.Accepted => "tenant-yonetim__badge--accepted",
        _ => "tenant-yonetim__badge--archived"
    };
}

<div class="form-section form-section--narrow">
    <h1 class="form-section__title">@Model.Tenant.Name — Yönetim</h1>

    @if (TempData["Success"] is string success)
    {
        <div class="form-section__message form-section__message--success" role="status">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="form-section__message form-section__message--error" role="alert">@error</div>
    }

    <p class="field-hint tenant-yonetim__meta">
        Slug: <code>@Model.Tenant.Slug</code> · Üye sayısı: @Model.Tenant.Members.Count
    </p>

    <h2 class="form-section__title tenant-yonetim__section-title">Üyeler</h2>
    <div class="tenant-yonetim__table-wrap">
        <table class="tenant-yonetim__table">
            <thead>
                <tr>
                    <th>E-posta</th>
                    <th>Rol</th>
                    @if (Model.IsOwner)
                    {
                        <th class="tenant-yonetim__actions">Eylem</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Tenant.Members)
                {
                    <tr>
                        <td><span class="tenant-yonetim__email">@m.Email</span></td>
                        <td>
                            @if (m.Id == Model.Tenant.OwnerUserId)
                            {
                                <span class="tenant-yonetim__badge tenant-yonetim__badge--owner">Owner</span>
                            }
                            else
                            {
                                <span class="tenant-yonetim__badge tenant-yonetim__badge--member">Üye</span>
                            }
                        </td>
                        @if (Model.IsOwner)
                        {
                            <td class="tenant-yonetim__actions">
                                @if (m.Id != Model.Tenant.OwnerUserId)
                                {
                                    <form method="post" asp-action="UyeCikar" asp-route-id="@m.Id"
                                          onsubmit="return confirm('Bu üyeyi çıkarmak istediğinize emin misiniz?');"
                                          class="tenant-yonetim__inline-form">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="form-section__cta-link-btn">Çıkar</button>
                                    </form>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.IsOwner)
    {
        <h2 class="form-section__title tenant-yonetim__section-title tenant-yonetim__section-title--wide">Yeni Davet</h2>
        <form method="post" asp-action="Davet">
            @Html.AntiForgeryToken()
            <div class="field">
                <label class="field__label" for="invitation-email">Davet edilecek e-posta</label>
                <input id="invitation-email" name="Email" type="email" class="field__input"
                       required maxlength="256" placeholder="ornek@eposta.com" />
            </div>
            <div class="form-section__actions">
                <button type="submit" class="btn btn--primary">Davet Gönder</button>
            </div>
        </form>

        <h2 class="form-section__title tenant-yonetim__section-title tenant-yonetim__section-title--wide">Davetler</h2>
        @if (Model.Invitations.Count == 0)
        {
            <p class="field-hint tenant-yonetim__empty">Henüz hiç davet gönderilmedi.</p>
        }
        else
        {
            <div class="tenant-yonetim__table-wrap">
                <table class="tenant-yonetim__table">
                    <thead>
                        <tr>
                            <th>E-posta</th>
                            <th>Durum</th>
                            <th>Gönderim</th>
                            <th>Bitiş</th>
                            <th class="tenant-yonetim__actions">Eylem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in Model.Invitations)
                        {
                            <tr>
                                <td><span class="tenant-yonetim__email">@inv.Email</span></td>
                                <td><span class="tenant-yonetim__badge @StatusBadge(inv.Status)">@StatusLabel(inv.Status)</span></td>
                                <td>@inv.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                <td>@inv.ExpiresAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                <td class="tenant-yonetim__actions">
                                    @if (inv.Status == TenantInvitationStatus.Pending && !inv.IsExpired)
                                    {
                                        <form method="post" asp-action="DavetIptal" asp-route-id="@inv.Id"
                                              onsubmit="return confirm('Daveti iptal etmek istediğinize emin misiniz?');"
                                              class="tenant-yonetim__inline-form">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="form-section__cta-link-btn">İptal Et</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {
        <div class="tenant-leave">
            <p class="field-hint">Tenant'tan ayrılırsanız ekibin paylaştığı hesaplara erişiminiz kalkar; sizin daha önce paylaştığınız hesaplar ekipte kalmaya devam eder.</p>
            <form method="post" asp-action="Ayril"
                  onsubmit="return confirm('Tenant\'tan ayrılmak istediğinize emin misiniz?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="tenant-leave__btn">Tenant'tan Ayrıl</button>
            </form>
        </div>
    }
</div>
