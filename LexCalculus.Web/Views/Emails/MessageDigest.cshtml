@model LexCalculus.Core.Email.Models.MessageDigestEmailModel
@{
    Layout = "/Views/Emails/_EmailLayout.cshtml";
    ViewBag.Title = "Lex Calculus — Yeni Mesajlarınız";
    var senders = Model.SenderDisplayNames.Distinct().ToList();
}

<h1 style="margin:0 0 20px 0;font-family:Georgia,serif;font-size:24px;color:#0a1428;font-weight:normal;">
  Yeni Mesajlarınız Var
</h1>

<p style="margin:0 0 18px 0;font-size:16px;line-height:1.6;color:#0a1428;">
  Merhaba @Model.RecipientDisplayName,
</p>

<p style="margin:0 0 18px 0;font-size:16px;line-height:1.6;color:#0a1428;">
  Son birkaç dakika içinde <strong style="color:#6b1f2e;">@Model.UnreadCount yeni mesaj</strong>
  aldınız.
</p>

@if (senders.Count > 0)
{
  <p style="margin:0 0 8px 0;font-size:14px;line-height:1.6;color:#0a1428;opacity:0.8;">
    Gönderenler:
  </p>
  <ul style="margin:0 0 24px 0;padding-left:20px;line-height:1.8;color:#0a1428;">
    @foreach (var sender in senders)
    {
      <li>@sender</li>
    }
  </ul>
}

<div style="text-align:center;margin:28px 0;">
  <a href="@Model.MessagesUrl"
     style="display:inline-block;padding:14px 28px;background-color:#0a1428;color:#f4ede0;font-family:'Courier New',monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;border:1px solid #b8924a;">
    Mesajları Görüntüle
  </a>
</div>

<p style="margin:24px 0 0 0;font-size:13px;color:#0a1428;opacity:0.7;font-style:italic;line-height:1.6;">
  Bu bildirimleri almak istemiyorsanız profil sayfanızdan e-posta tercihlerinizi
  güncelleyebilirsiniz.
</p>
