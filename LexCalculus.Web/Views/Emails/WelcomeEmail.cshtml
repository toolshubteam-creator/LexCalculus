@model LexCalculus.Core.Email.Models.WelcomeEmailModel
@{
    Layout = "/Views/Emails/_EmailLayout.cshtml";
    ViewBag.Title = "Lex Calculus — Hoş Geldiniz";
}

<h1 style="margin:0 0 20px 0;font-family:Georgia,serif;font-size:26px;color:#0a1428;font-weight:normal;">
  Lex Calculus'a Hoş Geldiniz
</h1>

<p style="margin:0 0 18px 0;font-size:16px;line-height:1.6;color:#0a1428;">
  Merhaba @Model.DisplayName,
</p>

<p style="margin:0 0 18px 0;font-size:16px;line-height:1.6;color:#0a1428;">
  Hesabınız aktifleştirildi. Türkiye'nin hukuki hesaplama platformuna katıldığınız
  için teşekkür ederiz. Tüm hesaplayıcılarımız ücretsiz, kayıt gerektirmeden
  kullanılabilir; ancak hesabınız ile <em>geçmişiniz, bildirimleriniz ve
  kişisel ayarlarınız</em> korunur.
</p>

<div style="border:1px solid #e8d9a8;border-left:4px solid #b8924a;padding:18px 20px;margin:24px 0;background-color:#fffdf8;">
  <p style="margin:0 0 14px 0;font-family:Georgia,serif;font-size:17px;font-weight:bold;color:#0a1428;">
    Başlamak için
  </p>

  <table cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:0;">
    <tr>
      <td style="padding:8px 0;font-size:14px;color:#0a1428;line-height:1.6;">
        <a href="@Model.CalculatorsUrl" style="color:#6b1f2e;text-decoration:none;">→ Hesaplayıcılarımıza göz atın</a>
      </td>
    </tr>
    <tr>
      <td style="padding:8px 0;font-size:14px;color:#0a1428;line-height:1.6;">
        <a href="@Model.ProfileUrl" style="color:#6b1f2e;text-decoration:none;">→ Profil bilgilerinizi tamamlayın</a>
      </td>
    </tr>
  </table>
</div>

<p style="margin:24px 0 8px 0;font-size:14px;line-height:1.6;color:#0a1428;opacity:0.85;">
  Sorularınız veya geri bildiriminiz varsa bu e-postaya yanıt verebilirsiniz.
  Sizden haber almaktan memnuniyet duyarız.
</p>

<p style="margin:16px 0 0 0;font-family:Georgia,serif;font-size:15px;color:#0a1428;font-style:italic;">
  İyi çalışmalar,<br/>
  Lex Calculus Ekibi
</p>
