@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<section class="hero">
    <div class="hero__eyebrow">— Beklenmedik durum —</div>
    <h1 class="hero__title">Bir <em>hata</em> oluştu.</h1>
    <p class="hero__lead">İsteğiniz işlenirken beklenmeyen bir sorun yaşandı. Bu hata kayıt altına alındı; teknik ekibimiz inceleyecektir.</p>
</section>

@if (Model.ShowRequestId)
{
    <div class="info-box">
        <strong>Hata referans no:</strong> <code>@Model.RequestId</code>
    </div>
}

<div style="text-align: center; margin-top: var(--sp-12);">
    <a class="btn btn--primary" asp-controller="Home" asp-action="Index">Ana sayfaya dön</a>
</div>
