@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var trCulture = new CultureInfo("tr-TR");
    var currentDate = DateTime.Now.ToString("dd MMMM yyyy", trCulture);
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    @await Component.InvokeAsync("SeoMeta")

    @if (ViewData["NoIndex"] is bool noIndex && noIndex)
    {
        <meta name="robots" content="noindex,nofollow" />
    }

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />

    @await RenderSectionAsync("Head", required: false)
</head>
<body>

    <header class="site-header">
        <div class="header-top">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">Lex<span class="brand-mark__accent">Calculus</span></span>
                <span class="brand-tagline">Hukuki Hesaplama Platformu</span>
            </a>

            <div class="header-meta">
                @if (SignInManager.IsSignedIn(User))
                {
                    <div>@User.Identity?.Name</div>
                    <div class="header-meta__user-actions">
                        @await Component.InvokeAsync("NotificationBell")
                        <a class="header-meta__link" href="/hesaplarim">Hesaplarım</a>
                        <a class="header-meta__link" href="/profil">Profilim</a>
                        @{
                            var currentUser = await UserManager.GetUserAsync(User);
                            var canRequestTenant = currentUser != null && !currentUser.TenantId.HasValue;
                        }
                        @if (canRequestTenant)
                        {
                            <a class="header-meta__link" href="/tenant-talep">Tenant Talebim</a>
                        }
                        <form class="header-meta__logout" asp-area="Identity" asp-page="/Account/Logout" method="post">
                            <button type="submit" class="header-meta__logout-btn">Çıkış</button>
                        </form>
                    </div>
                }
                else
                {
                    <div>
                        <a class="header-meta__link" asp-area="Identity" asp-page="/Account/Login">Giriş</a>
                        <a class="header-meta__link" asp-area="Identity" asp-page="/Account/Register">Kayıt Ol</a>
                    </div>
                }
                <div class="date">@currentDate</div>
            </div>
        </div>

        <nav class="tab-nav" aria-label="Ana navigasyon">
            <a class="tab @(currentController == "Home" ? "tab--active" : string.Empty)"
               asp-controller="Home" asp-action="Index">
                <span class="tab__num">00</span>Ana Sayfa
            </a>
            <a class="tab @(currentController == "Hesapla" ? "tab--active" : string.Empty)"
               asp-controller="Hesapla" asp-action="Index">
                <span class="tab__num">01</span>Hesaplama
            </a>
        </nav>
    </header>

    <main class="container">
        @if (TempData["RestoreWarning"] is string restoreWarning)
        {
            <div class="restore-warning">@restoreWarning</div>
        }
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="site-footer__disclaimer">⚖ Hesaplamalar yardımcı niteliktedir, hukuki bağlayıcılığı yoktur.</div>
        <div>© @DateTime.Now.Year Lex Calculus · Tüm hakları saklıdır</div>
    </footer>

    <script src="~/js/notifications.js" defer asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
