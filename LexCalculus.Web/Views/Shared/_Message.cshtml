@model LexCalculus.Web.Models.MessageViewModel

<div class="mesaj @(Model.IsOwnMessage ? "mesaj--own" : "mesaj--other")"
     id="mesaj-@Model.Id" data-message-id="@Model.Id">
    @if (!Model.IsOwnMessage)
    {
        <div class="mesaj__avatar">
            @if (!string.IsNullOrEmpty(Model.SenderAvatarUrl))
            {
                <img src="@Model.SenderAvatarUrl" alt="@Model.SenderDisplayName" />
            }
            else
            {
                <span class="mesaj__avatar-placeholder" aria-hidden="true">
                    @(Model.SenderDisplayName.Length > 0
                        ? Model.SenderDisplayName.Substring(0, 1).ToUpperInvariant()
                        : "?")
                </span>
            }
        </div>
    }

    <div class="mesaj__content">
        @if (Model.IsDeleted)
        {
            <p class="mesaj__deleted">(Bu mesaj silindi)</p>
        }
        else if (Model.IsModeratorHidden)
        {
            @* Faz 5.7 — admin moderasyon gizleme. Sahip için placeholder
               (alıcı için MessageService zaten liste'den filter eder). *@
            <p class="mesaj__hidden">(Yönetim tarafından gizlendi)</p>
        }
        else
        {
            <div class="mesaj__body" data-mesaj-body>@Html.Raw(Model.Body)</div>
        }

        <div class="mesaj__meta">
            <time datetime="@Model.CreatedAt.ToString("o")">
                @Model.CreatedAt.ToLocalTime().ToString("HH:mm")
            </time>

            @if (!Model.IsDeleted && !Model.IsModeratorHidden)
            {
                @* Faz 5.7 — kebab menü: own=Sil, other=Şikayet Et *@
                <div class="mesaj__menu">
                    <button type="button" class="mesaj__menu-toggle"
                            aria-label="Mesaj menüsü" aria-haspopup="menu" aria-expanded="false"
                            data-mesaj-menu-toggle>
                        ⋯
                    </button>
                    <div class="mesaj__menu-items" role="menu" hidden data-mesaj-menu-items>
                        @if (Model.IsOwnMessage)
                        {
                            <button type="button" class="mesaj__menu-item mesaj__delete"
                                    role="menuitem"
                                    data-mesaj-delete data-message-id="@Model.Id">
                                Sil
                            </button>
                        }
                        else
                        {
                            <button type="button"
                                    class="mesaj__menu-item mesaj__menu-item--danger"
                                    role="menuitem"
                                    data-report-target-type="3"
                                    data-report-target-id="@Model.Id">
                                Şikayet Et
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
